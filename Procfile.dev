# Rails on :3000, the Tailwind watcher, and the WhatsApp sidecar on :3001.
# The sidecar shares a bearer token with Rails (WHATSAPP_SERVICE_TOKEN ↔ RAILS_API_TOKEN):
# both default to a dev-only value here; export WHATSAPP_SERVICE_TOKEN to override both.
# PORT=3001 is forced inline so it wins over foreman's per-process PORT assignment.
# The sidecar auto-reconnects on boot (SKIP_AUTO_RECONNECT unset), restoring the saved
# LocalAuth session ~2s after start — so `bin/dev` comes up already connected, no manual
# "Connect" click. (It launches headless Chrome each boot; set SKIP_AUTO_RECONNECT=true if
# you'd rather connect on demand from /admin/whatsapp_connection.)
# SKIP_HISTORY_FILTER=true because this dev machine's clock is ahead of WhatsApp's message
# timestamps, which would otherwise drop every live message as "historical" (prod: leave off).
# The machine-specific Chromium path lives in whatsapp-sidecar/.env (gitignored).
web: WHATSAPP_SERVICE_TOKEN=${WHATSAPP_SERVICE_TOKEN:-dev-whatsapp-token} bin/rails server
css: bin/rails tailwindcss:watch
sidecar: cd whatsapp-sidecar && PORT=3001 SKIP_HISTORY_FILTER=true RAILS_WEBHOOK_URL=http://localhost:3000/api/whatsapp/webhook RAILS_API_TOKEN=${WHATSAPP_SERVICE_TOKEN:-dev-whatsapp-token} npm start
