<%# locals: bank_account — the name block links to edit (a pen fades in on hover);
    attribution + remove live on the edit page, not the row. %>
<div id="<%= dom_id(bank_account) %>" class="flex items-center gap-3 rounded-box border border-base-300/70 bg-base-100 p-3 shadow-sm">
  <%= link_to edit_bank_account_path(bank_account), class: "group flex min-w-0 flex-1 items-center gap-3",
        aria: { label: t("bank_accounts.edit_title") } do %>
    <%= institution_avatar(bank_account.institution, size: 40) %>
    <div class="min-w-0 flex-1">
      <p class="flex items-center gap-1.5 truncate text-sm font-semibold">
        <span class="truncate"><%= bank_account.display_name %></span>
        <% unless bank_account.checking? %>
          <span class="badge badge-xs <%= bank_account.savings? ? "badge-success" : "badge-info" %>"><%= t("bank_accounts.kinds.#{bank_account.kind}") %></span>
        <% end %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0 opacity-0 transition-opacity group-hover:opacity-50 group-focus-visible:opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zM19.5 7.125L16.875 4.5" /></svg>
      </p>
      <p class="truncate text-xs text-base-content/50">
        <%= bank_account.institution.display_name %>
        <% details = [ bank_account.agency, bank_account.account_number ].compact_blank %>
        <% if details.any? %>· <%= details.join(" / ") %><% end %>
      </p>
    </div>
  <% end %>

  <div class="shrink-0 text-right">
    <% if bank_account.balance_informed? %>
      <% derived = bank_account.derived_balance_cents %>
      <p class="font-display text-sm font-bold tabular-nums"><%= brl(derived) %></p>
      <%# Livre vs guardado-para-meta (round 3 decision 7), clamped — derived counts rows by
          created_at-after-anchor while earmarks count by billing_month, so a re-anchored
          balance can momentarily disagree; never render a negative "livre". %>
      <% if (reserved = goal_reserved_cents(bank_account)).positive? %>
        <p class="text-xs tabular-nums text-base-content/50"><%= t("bank_accounts.free_balance", amount: brl([ derived - reserved, 0 ].max)) %></p>
        <p class="text-xs tabular-nums text-base-content/50"><%= t("bank_accounts.reserved_for_goal", amount: brl([ [ reserved, derived ].min, 0 ].max)) %></p>
      <% end %>
    <% else %>
      <p class="text-xs text-base-content/40"><%= t("bank_accounts.no_balance") %></p>
    <% end %>
  </div>
</div>
