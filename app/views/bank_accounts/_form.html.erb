<%# locals: bank_account %>
<%# The create form (index/onboarding) posts to a Turbo Stream and resets on success; the
    full-page edit form PATCHes and redirects, so it skips form-reset. %>
<%= form_with model: bank_account,
      url: (bank_account.persisted? ? bank_account_path(bank_account) : bank_accounts_path),
      id: "bank_account_form",
      data: (bank_account.persisted? ? {} : { controller: "form-reset", action: "turbo:submit-end->form-reset#reset" }),
      class: "flex flex-col gap-4" do |f| %>
  <div id="bank_account_form_errors">
    <%= render "bank_accounts/form_errors", record: bank_account %>
  </div>

  <%= render "shared/institution_select", form: f, institutions: Institution.for_accounts %>

  <div class="form-control">
    <%= f.label :nickname, t("bank_accounts.nickname"), class: "mb-1 block text-sm font-medium" %>
    <%= f.text_field :nickname, placeholder: t("bank_accounts.nickname_placeholder"), class: "input input-bordered w-full" %>
  </div>

  <%# Checking vs savings (R4) — a savings account is treated as a "caixinha" by the metrics. %>
  <div class="form-control">
    <label class="mb-1 block text-sm font-medium"><%= t("activerecord.attributes.bank_account.kind") %></label>
    <div class="join">
      <% BankAccount.kinds.each_key do |k| %>
        <label class="join-item btn btn-sm font-normal has-checked:btn-primary">
          <%= f.radio_button :kind, k, class: "hidden", checked: (bank_account.kind == k) %>
          <%= t("bank_accounts.kinds.#{k}") %>
        </label>
      <% end %>
    </div>
    <p class="mt-2 text-xs text-base-content/50"><%= t("bank_accounts.form.kind_hint") %></p>
  </div>

  <%# Optional details — nothing here is required. Opened up-front on edit when already set. %>
  <% has_details = bank_account.balance_informed? || bank_account.agency.present? || bank_account.account_number.present? %>
  <details class="group" <%= "open" if has_details %>>
    <summary class="flex cursor-pointer list-none items-center gap-1 text-sm font-medium text-primary">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
      <%= t("bank_accounts.optional_details") %>
    </summary>
    <div class="mt-3 grid gap-4 sm:grid-cols-2">
      <div class="form-control">
        <%= f.label :balance_reais, t("bank_accounts.balance"), class: "mb-1 block text-sm font-medium" %>
        <label class="input input-bordered flex w-full items-center gap-2">
          <span class="text-base-content/50"><%= t("money.symbol") %></span>
          <%= f.text_field :balance_reais, inputmode: "decimal", placeholder: "0,00", class: "grow",
                data: { controller: "money-mask", money_mask_cents_value: true, action: "input->money-mask#format" } %>
        </label>
      </div>
      <div class="form-control">
        <%= f.label :agency, t("bank_accounts.agency"), class: "mb-1 block text-sm font-medium" %>
        <%= f.text_field :agency, inputmode: "numeric", placeholder: t("bank_accounts.agency_placeholder"), class: "input input-bordered w-full" %>
      </div>
      <div class="form-control sm:col-span-2">
        <%= f.label :account_number, t("bank_accounts.account_number"), class: "mb-1 block text-sm font-medium" %>
        <%= f.text_field :account_number, inputmode: "numeric", placeholder: t("bank_accounts.account_number_placeholder"), class: "input input-bordered w-full" %>
      </div>
    </div>
  </details>

  <%# Edit footer: attribution + the (dangerous) remove on the left, save on the right. The
      remove is a turbo_method link, not a button_to — a nested <form> here would be invalid. %>
  <div class="flex items-center justify-between gap-2">
    <div class="flex items-center gap-2">
      <% if bank_account.persisted? %>
        <%= link_to t("bank_accounts.remove"), bank_account_path(bank_account),
              data: { turbo_method: :delete, turbo_confirm: t("bank_accounts.confirm_remove") },
              class: "btn btn-ghost btn-sm text-error" %>
      <% end %>
    </div>
    <%= f.submit (bank_account.persisted? ? t("bank_accounts.save") : t("bank_accounts.add")), class: "btn btn-primary btn-sm" %>
  </div>
<% end %>
