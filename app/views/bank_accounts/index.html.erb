<% content_for :title, t("bank_accounts.index.meta_title") %>

<header class="mb-6">
  <h1 data-native-dup class="font-display text-2xl font-extrabold tracking-tight"><%= t("bank_accounts.index.title") %></h1>
  <p class="text-sm text-base-content/60"><%= t("bank_accounts.index.subtitle") %></p>
</header>

<div class="grid gap-6 lg:grid-cols-5">
  <div class="lg:col-span-3">
    <div id="bank_accounts_list" class="flex flex-col gap-3">
      <% if @bank_accounts.any? %>
        <%= render @bank_accounts %>
      <% else %>
        <%= render "bank_accounts/empty" %>
      <% end %>
    </div>
  </div>

  <div class="lg:col-span-2">
    <%# One card: the manual form, or import an extrato and let the review create the
        account + entries (post-onboarding surface of D1 — same uploader as the wizard
        step, which keeps its own hero + trailing divider). %>
    <%= render layout: "shared/add_card", locals: { title: t("bank_accounts.add_title") } do %>
      <%= render "bank_accounts/form", bank_account: @bank_account %>
      <div class="divider text-xs text-base-content/50"><%= t("bank_accounts.import.divider") %></div>
      <%= render "document_imports/uploader", title: t("bank_accounts.import.title"),
            tooltip: t("bank_accounts.import.tooltip"), trailing_divider: false %>
    <% end %>
  </div>
</div>
