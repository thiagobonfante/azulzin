<%# locals: bill, paid_cents (Σ payments including the amount being typed) — the honest
    partial-payment warning (.plans/credit-cards 02 §4). Renders beside the field, never
    blocks, never a red wall. Empty when the payment covers the bill.
    Founder round 2026-07-22: headline split at the dash, estimate label on its own line,
    the 4-stat grid reduced to the two facts + one plain-words sentence explaining the
    12x parcelamento, and the whole bar chart is the month-by-month expander. %>
<% total = bill.effective_total_cents %>
<%# A financed bill left the rotativo — its remainder is contracted parcels, so the
    rotativo projection would be flatly wrong (founder 2026-07-22d). %>
<% if paid_cents.positive? && paid_cents < total && !bill.financed? %>
  <% rot  = BcbRate.current("rotativo") %>
  <% parc = BcbRate.current("parcelamento") %>
  <% min_cents = bill.stated_minimum_cents || (total * 15 / 100) %>
  <div class="rounded-box border border-warning/40 bg-warning/10 p-3 text-xs" role="status">
    <p class="font-medium"><%= t("card_bills.rotativo.below_total") %></p>
    <p class="mt-0.5 text-base-content/70">
      <% if rot %>
        <%= t("card_bills.rotativo.below_total_rate", rate: number_with_precision(rot.monthly_rate, precision: 1)) %>
      <% else %>
        <%= t("card_bills.rotativo.below_total_generic") %>
      <% end %>
    </p>
    <% if paid_cents < min_cents %>
      <p class="mt-1">
        <%= t("card_bills.rotativo.below_minimum",
              minimum: brl(min_cents),
              label: (bill.stated_minimum_cents ? "" : t("card_bills.rotativo.assumed_minimum"))).strip %>
      </p>
    <% end %>

    <% if rot && parc && (proj = Rotativo.projection(total, paid_cents,
                                                     rotativo_am: rot.monthly_rate, parcelado_am: parc.monthly_rate)) %>
      <%# Founder round 2026-07-22b: shallow on purpose — what stays behind, what LANDS on
          the next bill (fees included), and a one-line parcelamento nudge. No 12x model,
          no chart; revisit depth when real usage asks for it. %>
      <div class="mt-2 border-t border-warning/30 pt-2">
        <p class="font-medium text-base-content/70"><%= t("card_bills.rotativo.panel_title", amount: brl(total - proj[:financed_cents])) %></p>
        <p class="text-base-content/40"><%= t("card_bills.carryover.estimate_label", month: (l(rot.reference_month, format: :month_year))) %></p>
        <div class="mt-2 grid grid-cols-2 gap-x-3 gap-y-1">
          <div><p class="text-base-content/50"><%= t("card_bills.rotativo.left_behind") %></p><p class="font-medium tabular-nums"><%= brl(proj[:financed_cents]) %></p></div>
          <div>
            <p class="text-base-content/50"><%= t("card_bills.rotativo.next_bill_total") %></p>
            <p class="font-medium tabular-nums"><%= brl(proj[:financed_cents] + proj[:next_bill_add_cents]) %></p>
            <p class="text-base-content/50"><%= t("card_bills.rotativo.next_bill_fees", amount: brl(proj[:next_bill_add_cents])) %></p>
          </div>
        </div>
        <p class="mt-2 text-base-content/70"><%= t("card_bills.rotativo.parcelamento_hint") %></p>
        <p class="mt-2 text-base-content/60"><%= t("card_bills.rotativo.cap_reassurance", months: proj[:months_to_cap]) %></p>
      </div>
    <% end %>
  </div>
<% end %>
