<%# locals: commitment %>
<%= form_with model: commitment, url: commitments_path, id: "commitment_form",
      data: { controller: "commitment-form form-reset", action: "turbo:submit-end->form-reset#reset" },
      class: "flex flex-col gap-4" do |f| %>
  <div id="commitment_form_errors">
    <% if commitment.errors.any? %>
      <div class="alert alert-error py-2 text-sm" role="alert"><span><%= commitment.errors.full_messages.to_sentence %></span></div>
    <% end %>
  </div>

  <div class="flex flex-col gap-1">
    <% Commitment.kinds.each_key do |kind| %>
      <label class="flex cursor-pointer items-start gap-2 rounded-box border border-base-300/70 p-2 has-checked:border-primary has-checked:bg-primary/5">
        <%= f.radio_button :kind, kind, checked: (commitment.kind || "installment") == kind, class: "mt-1",
              data: { commitment_form_target: "kind", action: "commitment-form#toggle" } %>
        <span>
          <span class="block text-sm font-medium"><%= t("commitments.kinds.#{kind}") %></span>
          <span class="block text-xs text-base-content/50"><%= t("commitments.form.kind_hints.#{kind}") %></span>
        </span>
      </label>
    <% end %>
  </div>

  <div class="form-control">
    <%= f.label :name, t("commitments.form.name"), class: "mb-1 block text-sm font-medium" %>
    <%= f.text_field :name, required: true, class: "input input-bordered w-full" %>
  </div>

  <div class="form-control">
    <%= f.label :amount_reais, t("commitments.form.amount"), class: "mb-1 block text-sm font-medium" %>
    <label class="input input-bordered flex w-full items-center gap-2">
      <span class="text-base-content/50"><%= t("money.symbol") %></span>
      <%= f.text_field :amount_reais, inputmode: "decimal", required: true, placeholder: "0,00", class: "grow" %>
    </label>
  </div>

  <div class="grid gap-3 sm:grid-cols-2" data-commitment-form-target="installment">
    <div class="form-control">
      <%= f.label :installments_count, t("commitments.form.installments_count"), class: "mb-1 block text-sm font-medium" %>
      <%= f.number_field :installments_count, min: 1, class: "input input-bordered w-full" %>
    </div>
    <div class="form-control">
      <label class="mb-1 block text-sm font-medium"><%= t("commitments.form.installments_paid") %></label>
      <%= number_field_tag "commitment[installments_paid]", 0, min: 0, class: "input input-bordered w-full" %>
    </div>
  </div>

  <div class="form-control">
    <%= f.label :schedule_day, t("commitments.form.schedule_day"), class: "mb-1 block text-sm font-medium" %>
    <%= f.select :schedule_day, (1..31).to_a, { include_blank: t("commitments.form.schedule_day_optional") }, class: "select select-bordered w-full" %>
    <span class="mt-1 hidden text-xs text-base-content/50" data-commitment-form-target="cardHint"><%= t("commitments.form.day_card_hint") %></span>
  </div>

  <details class="form-control" data-commitment-form-target="fixed">
    <summary class="cursor-pointer list-none text-sm text-primary"><%= t("commitments.form.ends_on") %></summary>
    <%= f.date_field :ends_on, class: "input input-bordered mt-1 w-full" %>
  </details>

  <div class="form-control">
    <%= f.label :category_id, t("transactions.row.category"), class: "mb-1 block text-sm font-medium" %>
    <%= f.collection_select :category_id, Current.user.categories.ordered, :id, :name,
          { include_blank: t("transactions.ledger.uncategorized") }, class: "select select-bordered w-full" %>
  </div>

  <div class="form-control">
    <label class="mb-1 block text-sm font-medium"><%= t("commitments.form.instrument") %></label>
    <%= select_tag "instrument", grouped_options_for_select(instrument_option_groups),
          include_blank: false, class: "select select-bordered w-full",
          data: { commitment_form_target: "instrument", action: "commitment-form#toggle" } %>
  </div>

  <div class="flex justify-end">
    <%= f.submit t("commitments.form.submit"), class: "btn btn-primary btn-sm" %>
  </div>
<% end %>
