<%# locals: commitments, archived — the grouped list body (re-rendered on create/destroy).
    Each kind is a collapsible group headed by its count + monthly subtotal, so a long list
    (e.g. imported subscriptions) can be folded away while staying summable at a glance. %>
<% if commitments.any? %>
  <div class="flex items-center justify-between rounded-box border border-base-300/70 bg-base-100 px-4 py-3 shadow-sm">
    <span class="text-sm text-base-content/60"><%= t("commitments.index.total_committed") %></span>
    <span class="font-display font-bold tabular-nums"><%= brl(commitments.sum(&:amount_cents)) %></span>
  </div>

  <% grouped = commitments.group_by(&:kind) %>
  <% %w[installment fixed subscription].each do |kind| %>
    <% next unless (group = grouped[kind]) %>
    <details open class="group">
      <summary class="mb-2 flex cursor-pointer list-none items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-base-content/40 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
        <span class="text-xs font-semibold uppercase tracking-wide text-base-content/50"><%= t("commitments.kinds.#{kind}") %></span>
        <span class="badge badge-ghost badge-xs tabular-nums"><%= group.size %></span>
        <span class="ml-auto text-sm font-semibold tabular-nums text-base-content/70"><%= brl(group.sum(&:amount_cents)) %></span>
      </summary>
      <div class="flex flex-col gap-2"><%= render group %></div>
    </details>
  <% end %>
<% else %>
  <%= render "commitments/empty" %>
<% end %>

<% if archived.any? %>
  <details class="group">
    <summary class="cursor-pointer list-none text-sm text-base-content/50"><%= t("commitments.index.archived", count: archived.size) %></summary>
    <div class="mt-2 flex flex-col gap-2 opacity-60"><%= render archived %></div>
  </details>
<% end %>
