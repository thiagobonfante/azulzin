<%# locals: commitments, archived — the grouped list body (re-rendered on create/destroy).
    Each kind is a collapsible group headed by its count + monthly subtotal, so a long list
    (e.g. imported subscriptions) can be folded away while staying summable at a glance. %>
<% if commitments.any? %>
  <%# The total card doubles as the filter readout: with a search/filter active the
      commitments-filter controller swaps the label and sums only the visible rows. %>
  <div class="flex items-center justify-between gap-3 rounded-box border border-base-300/70 bg-base-100 px-4 py-3 shadow-sm">
    <span class="min-w-0 truncate text-sm text-base-content/60" data-commitments-filter-target="totalLabel"
          data-label-all="<%= t("commitments.index.total_committed") %>"
          data-label-filtered="<%= t("commitments.index.total_filtered") %>"><%= t("commitments.index.total_committed") %></span>
    <span class="shrink-0 font-display font-bold tabular-nums" data-commitments-filter-target="totalValue"
          data-total-cents="<%= commitments.sum(&:amount_cents) %>"><%= brl(commitments.sum(&:amount_cents)) %></span>
  </div>

  <% grouped = commitments.group_by(&:kind) %>
  <% %w[installment fixed subscription].each do |kind| %>
    <% next unless (group = grouped[kind]) %>
    <details open class="group" data-commitments-filter-target="group">
      <summary class="mb-2 flex cursor-pointer list-none items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 shrink-0 text-base-content/40 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
        <span class="min-w-0 truncate text-xs font-semibold uppercase tracking-wide text-base-content/50"><%= t("commitments.kinds.#{kind}") %></span>
        <span class="badge badge-ghost badge-xs shrink-0 tabular-nums"><%= group.size %></span>
        <span class="ml-auto shrink-0 text-sm font-semibold tabular-nums text-base-content/70"><%= brl(group.sum(&:amount_cents)) %></span>
      </summary>
      <div class="flex flex-col gap-2"><%= render group %></div>
    </details>
  <% end %>

  <p hidden data-commitments-filter-target="noResults" class="py-4 text-center text-sm text-base-content/50">
    <%= t("commitments.index.no_results") %>
  </p>
<% else %>
  <%= render "commitments/empty" %>
<% end %>

<% if archived.any? %>
  <details class="group">
    <summary class="cursor-pointer list-none text-sm text-base-content/50"><%= t("commitments.index.archived", count: archived.size) %></summary>
    <div class="mt-2 flex flex-col gap-2 opacity-60"><%= render archived %></div>
  </details>
<% end %>
