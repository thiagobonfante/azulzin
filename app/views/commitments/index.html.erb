<% content_for :title, t("commitments.index.meta_title") %>

<header class="mb-6">
  <h1 class="font-display text-2xl font-extrabold tracking-tight"><%= t("commitments.index.title") %></h1>
  <p class="text-sm text-base-content/60"><%= t("commitments.index.subtitle") %></p>
</header>

<div class="grid gap-6 lg:grid-cols-5">
  <div class="min-w-0 lg:col-span-3" data-controller="commitments-filter">
    <% if @commitments.any? %>
      <%# Search + a "Filtros" sheet — client-side over the loaded list (commitments-filter).
          Search fills the row with the buttons pushed right; category / instrument live in the
          sheet so mobile isn't a stack of selects. A clear (×) shows when a filter is set. %>
      <div class="mb-4 flex items-center gap-2" data-controller="modal">
        <label class="input input-bordered input-sm flex min-w-0 flex-1 items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 10.5a6.5 6.5 0 11-13 0 6.5 6.5 0 0113 0z" /></svg>
          <input type="search" data-commitments-filter-target="search" data-action="input->commitments-filter#apply"
                 placeholder="<%= t("commitments.index.search_placeholder") %>"
                 class="grow border-0 bg-transparent p-0 focus:outline-none" autocomplete="off">
        </label>

        <div class="ml-auto flex shrink-0 items-center gap-1">
          <button type="button" hidden data-commitments-filter-target="clearButton" data-action="commitments-filter#clear"
                  class="btn btn-sm btn-ghost btn-square text-base-content/50 hover:text-error"
                  aria-label="<%= t("transactions.ledger.filter_clear") %>">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
          <button type="button" data-commitments-filter-target="filterButton" data-action="modal#open" class="btn btn-sm btn-ghost gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z" /></svg>
            <%= t("transactions.ledger.filters_button") %>
            <span hidden data-commitments-filter-target="filterDot" class="h-2 w-2 rounded-full bg-primary" aria-hidden="true"></span>
          </button>
        </div>

        <dialog data-modal-target="dialog" class="modal modal-bottom sm:modal-middle">
          <div class="modal-box sm:max-w-sm text-left">
            <form method="dialog">
              <button class="btn btn-ghost btn-sm btn-circle absolute right-2 top-2" aria-label="<%= t("transactions.new_entry.close") %>">✕</button>
            </form>
            <h3 class="mb-4 font-display text-lg font-bold"><%= t("commitments.index.filter_sheet_title") %></h3>

            <div class="flex flex-col gap-4">
              <div>
                <p class="mb-1.5 text-xs font-medium text-base-content/60"><%= t("transactions.row.category") %></p>
                <select data-commitments-filter-target="category" data-action="change->commitments-filter#apply"
                        class="select select-bordered select-sm w-full" aria-label="<%= t("commitments.index.all_categories") %>">
                  <option value=""><%= t("commitments.index.all_categories") %></option>
                  <% Current.account.categories.kept.order(:name).each do |category| %>
                    <option value="<%= category.id %>"><%= category.name %></option>
                  <% end %>
                </select>
              </div>

              <div>
                <p class="mb-1.5 text-xs font-medium text-base-content/60"><%= t("transactions.row.instrument") %></p>
                <select data-commitments-filter-target="instrument" data-action="change->commitments-filter#apply"
                        class="select select-bordered select-sm w-full" aria-label="<%= t("commitments.index.all_instruments") %>">
                  <option value=""><%= t("commitments.index.all_instruments") %></option>
                  <% if inbox_bank_accounts.any? %>
                    <optgroup label="<%= t("transactions.ledger.filter_accounts") %>">
                      <% inbox_bank_accounts.each do |account| %>
                        <option value="bank_account-<%= account.id %>"><%= account.display_name %></option>
                      <% end %>
                    </optgroup>
                  <% end %>
                  <% if inbox_credit_cards.any? %>
                    <optgroup label="<%= t("transactions.ledger.filter_cards") %>">
                      <% inbox_credit_cards.each do |card| %>
                        <option value="credit_card-<%= card.id %>"><%= card.display_name %></option>
                      <% end %>
                    </optgroup>
                  <% end %>
                </select>
              </div>

              <div class="mt-1 flex gap-2">
                <button type="button" data-action="commitments-filter#clear modal#close" class="btn btn-ghost btn-sm flex-1"><%= t("transactions.ledger.filter_clear") %></button>
                <button type="button" data-action="modal#close" class="btn btn-primary btn-sm flex-1"><%= t("shared.done") %></button>
              </div>
            </div>
          </div>
          <form method="dialog" class="modal-backdrop">
            <button aria-label="<%= t("transactions.new_entry.close") %>">close</button>
          </form>
        </dialog>
      </div>
    <% end %>
    <div id="commitments_list" class="flex flex-col gap-4">
      <%= render "commitments/grouped_list", commitments: @commitments, archived: @archived %>
    </div>
  </div>

  <div class="min-w-0 lg:col-span-2">
    <%= render layout: "shared/add_card", locals: { title: t("commitments.index.new") } do %>
      <% if account_has_instruments? %>
        <%= render "commitments/form", commitment: @commitment %>
      <% else %>
        <%= render "shared/needs_instrument" %>
      <% end %>
    <% end %>
  </div>
</div>
