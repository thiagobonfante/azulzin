<% content_for :title, @commitment.name %>

<header class="mb-4">
  <%= link_to commitments_path, class: "mb-2 inline-flex items-center gap-1 text-sm text-base-content/50 hover:text-base-content" do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
    <%= t("app.nav.commitments") %>
  <% end %>
  <div class="flex items-start justify-between gap-2">
    <div class="flex flex-wrap items-center gap-2">
      <h1 class="font-display text-2xl font-extrabold tracking-tight"><%= @commitment.name %></h1>
      <span class="badge badge-ghost badge-sm"><%= t("commitments.kinds.#{@commitment.kind}") %></span>
      <span class="badge badge-ghost badge-sm"><%= @commitment.card? ? t("commitments.instrument.credit") : t("commitments.instrument.debit") %></span>
    </div>

    <%# Actions — edit, quitar (installments on debit) and encerrar, up top where they're visible. %>
    <div class="flex shrink-0 items-center gap-1">
      <details class="dropdown dropdown-end" data-controller="dropdown">
        <summary class="btn btn-ghost btn-sm btn-square tooltip tooltip-bottom text-base-content/50 hover:text-primary"
                 data-tip="<%= t("commitments.show.edit") %>" aria-label="<%= t("commitments.show.edit") %>">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zM19.5 7.125L16.875 4.5" /></svg>
        </summary>
        <div class="dropdown-content z-40 mt-1 w-80 rounded-box border border-base-300/70 bg-base-100 p-4 shadow-lg">
          <h2 class="mb-3 text-sm font-semibold"><%= t("commitments.show.edit") %></h2>
          <%= form_with model: @commitment, url: commitment_path(@commitment), method: :patch, class: "grid gap-3" do |f| %>
            <div class="form-control"><%= f.label :name, t("commitments.form.name"), class: "mb-1 text-xs" %><%= f.text_field :name, class: "input input-bordered input-sm w-full" %></div>
            <div class="form-control"><%= f.label :amount_reais, t("commitments.form.amount"), class: "mb-1 text-xs" %><%= f.text_field :amount_reais, inputmode: "decimal", class: "input input-bordered input-sm w-full" %></div>
            <div class="form-control"><%= f.label :schedule_day, t("commitments.form.schedule_day"), class: "mb-1 text-xs" %><%= f.select :schedule_day, (1..31).to_a, { include_blank: t("commitments.form.schedule_day_optional") }, class: "select select-bordered select-sm w-full" %></div>
            <div class="form-control">
              <label class="mb-1 text-xs"><%= t("transactions.row.category") %></label>
              <%= render "categories/picker", field_name: "commitment[category_id]", selected_id: @commitment.category_id %>
            </div>
            <div class="flex justify-end"><%= f.submit t("commitments.form.save"), class: "btn btn-primary btn-sm" %></div>
          <% end %>
        </div>
      </details>

      <% if @commitment.installment? && !@commitment.card? %>
        <details class="dropdown dropdown-end" data-controller="dropdown">
          <summary class="btn btn-ghost btn-sm btn-square tooltip tooltip-bottom text-base-content/50 hover:text-primary"
                   data-tip="<%= t("commitments.show.settle") %>" aria-label="<%= t("commitments.show.settle") %>">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>
          </summary>
          <div class="dropdown-content z-40 mt-1 w-72 rounded-box border border-base-300/70 bg-base-100 p-4 shadow-lg">
            <h2 class="mb-1 text-sm font-semibold"><%= t("commitments.show.settle") %></h2>
            <p class="mb-3 text-xs text-base-content/50"><%= t("commitments.show.settle_hint") %></p>
            <%= form_with url: settle_commitment_path(@commitment), method: :patch, class: "flex flex-col gap-2",
                  data: { turbo_confirm: t("commitments.show.settle_confirm") } do %>
              <label class="text-xs text-base-content/60"><%= t("commitments.occurrences.pay_amount") %></label>
              <label class="input input-bordered input-sm flex items-center gap-1">
                <span class="text-base-content/50"><%= t("money.symbol") %></span>
                <%# Prefill mirrors MoneyColumns' *_reais style ("1234,56"). %>
                <%= text_field_tag :amount_reais, format("%.2f", @commitment.remaining_cents.to_i.fdiv(100)).tr(".", ","),
                      inputmode: "decimal", required: true, class: "grow" %>
              </label>
              <%= submit_tag t("commitments.show.settle_submit"), class: "btn btn-primary btn-sm" %>
            <% end %>
          </div>
        </details>
      <% end %>

      <span class="tooltip tooltip-bottom" data-tip="<%= t("commitments.show.finish") %>">
        <%= button_to commitment_path(@commitment), method: :delete,
              class: "btn btn-ghost btn-sm btn-square text-base-content/50 hover:text-error",
              form: { data: { turbo_confirm: t("commitments.show.finish_confirm") } },
              aria: { label: t("commitments.show.finish") } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" /></svg>
        <% end %>
      </span>
    </div>
  </div>
  <p class="flex flex-wrap items-center gap-x-1.5 text-sm text-base-content/60">
    <% if (instrument = @commitment.instrument) %>
      <%= institution_avatar(instrument.institution, size: 20) %>
      <span class="font-medium text-base-content/80"><%= instrument.display_name %></span>
      <span>·</span>
    <% end %>
    <% phrase = commitment_schedule_phrase(@commitment) %><% if phrase.present? %><span><%= phrase %></span><span>·</span><% end %>
    <span><% if @commitment.installment? %><%= @commitment.installments_count %>× <%= brl(@commitment.amount_cents) %><% else %><%= brl(@commitment.amount_cents) %><% end %></span>
  </p>
  <% if @commitment.installment? %>
    <div class="mt-2 h-2 max-w-sm overflow-hidden rounded-full bg-base-200">
      <div class="h-full rounded-full bg-primary" style="width: <%= (@commitment.paid_count.fdiv(@commitment.installments_count) * 100).round %>%"></div>
    </div>
    <p class="mt-1 text-sm text-base-content/60">
      <%= t("commitments.row.progress", paid: @commitment.paid_count, count: @commitment.installments_count) %>
      · <%= t("commitments.show.remaining", amount: brl(@commitment.remaining_cents)) %>
    </p>
  <% end %>
</header>

<%= render "commitments/occurrences", commitment: @commitment %>

<p class="mt-3 text-xs text-base-content/50"><%= t("commitments.show.finish_hint") %></p>
