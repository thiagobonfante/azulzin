<%# locals: credit_card — the name block links to edit (a pen fades in on hover);
    attribution + remove live on the edit page, not the row. %>
<div id="<%= dom_id(credit_card) %>" class="rounded-box border border-base-300/70 bg-base-100 p-3 shadow-sm">
  <div class="flex items-center gap-3">
    <%# The per-member default star (04 §5): filled for MY default; one tap moves it.
        Only rendered when there is a choice — the one-plain-card page stays untouched. %>
    <% if show_default_star? %>
      <% is_default = Current.user.default_credit_card_id == credit_card.id %>
      <%= button_to make_default_credit_card_path(credit_card), method: :patch,
            class: "btn btn-ghost btn-xs btn-circle shrink-0 #{is_default ? "text-warning" : "text-base-content/30"}",
            title: t("credit_cards.default.set"), aria: { label: t("credit_cards.default.set") } do %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="<%= is_default ? "currentColor" : "none" %>" stroke="currentColor" stroke-width="1.8" class="h-4 w-4"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>
      <% end %>
    <% end %>
    <%= link_to edit_credit_card_path(credit_card), class: "group flex min-w-0 flex-1 items-center gap-3",
          aria: { label: t("credit_cards.edit_title") } do %>
      <%= institution_avatar(credit_card.institution, size: 40) %>
      <div class="min-w-0 flex-1">
        <p class="flex items-center gap-1.5 truncate text-sm font-semibold">
          <span class="truncate"><%= credit_card.display_name %></span>
          <% if credit_card.virtual? %>
            <span class="badge badge-info badge-xs"><%= t("credit_cards.card_types.virtual") %></span>
          <% end %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0 opacity-0 transition-opacity group-hover:opacity-50 group-focus-visible:opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zM19.5 7.125L16.875 4.5" /></svg>
        </p>
        <p class="truncate text-xs text-base-content/50">
          <%= credit_card.institution.display_name %>
          <% if credit_card.last4.present? %>· <%= t("credit_cards.ending", last4: credit_card.last4) %><% end %>
        </p>
      </div>
    <% end %>
  </div>

  <%# Billing config summary (R2) or a quiet nudge to set it. %>
  <% if credit_card.billing_configured? %>
    <p class="mt-2 text-xs text-base-content/50">
      <%= t("transactions.bills.due_on", day: credit_card.bill_due_day) %> ·
      <%= t("transactions.bills.closes_on", day: credit_card.closing_date(credit_card.current_open_bill_month).day) %>
    </p>
    <%# Newest unpaid closed fatura → the pay entry point (.plans/credit-cards 01 §4.2).
        ponytail: only the 3 newest bills are probed — older unpaid ones escalate via
        card_overdue instead of an unbounded scan on every page view. %>
    <% if (unpaid = credit_card.card_bills.order(billing_month: :desc).limit(3).detect { |b| !b.paid? }) %>
      <%= link_to card_bill_path(unpaid), class: "mt-2 inline-flex items-center gap-1.5 text-xs font-medium text-primary hover:underline" do %>
        <span class="badge badge-sm <%= card_bill_badge_class(unpaid) %>"><%= t("card_bills.status.#{unpaid.display_status}") %></span>
        <%= t("card_bills.badge.closed", amount: brl(unpaid.effective_total_cents)) %>
      <% end %>
    <% end %>
  <% else %>
    <%= link_to t("transactions.bills.setup_billing"), edit_credit_card_path(credit_card),
          class: "mt-2 inline-block text-xs font-medium text-primary hover:underline" %>
  <% end %>

  <%# Sub-cards (04 §3): a quiet chip only when children exist — the simple case (one
      plain card) renders no extra UI at all. Creation lives on the edit page. %>
  <% children = credit_card.children.kept.includes(:institution).order(:created_at).to_a %>
  <% if children.any? %>
    <details class="mt-2">
      <summary class="cursor-pointer text-xs font-medium text-primary">
        <%= t("credit_cards.sub_cards.chip", count: children.size) %>
      </summary>
      <ul class="mt-2 ml-6 flex flex-col gap-1.5">
        <% children.each do |sub| %>
          <li class="flex items-center gap-2 text-xs">
            <% sub_default = Current.user.default_credit_card_id == sub.id %>
            <%= button_to make_default_credit_card_path(sub), method: :patch,
                  class: "btn btn-ghost btn-xs btn-circle shrink-0 #{sub_default ? "text-warning" : "text-base-content/30"}",
                  title: t("credit_cards.default.set"), aria: { label: t("credit_cards.default.set") } do %>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="<%= sub_default ? "currentColor" : "none" %>" stroke="currentColor" stroke-width="1.8" class="h-3.5 w-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>
            <% end %>
            <%= institution_avatar(sub.institution, size: 20) %>
            <span class="min-w-0 flex-1 truncate">
              <%= sub.display_name %>
              <% if sub.last4.present? %><span class="text-base-content/50">· <%= t("credit_cards.ending", last4: sub.last4) %></span><% end %>
            </span>
            <% if sub.virtual? %><span class="badge badge-info badge-xs"><%= t("credit_cards.card_types.virtual") %></span><% end %>
            <%= link_to t("credit_cards.sub_cards.edit"), edit_credit_card_path(sub), class: "shrink-0 text-primary hover:underline" %>
          </li>
        <% end %>
      </ul>
    </details>
  <% end %>

  <% if credit_card.limit_informed? %>
    <% ratio = credit_card.usage_ratio %>
    <% bar = ratio >= 0.9 ? "bg-error" : ratio >= 0.7 ? "bg-warning" : "bg-primary" %>
    <div class="mt-3">
      <div class="flex items-baseline justify-between text-xs">
        <span class="text-base-content/50"><%= t("credit_cards.used") %> <span class="font-medium tabular-nums text-base-content/70"><%= brl(credit_card.used_cents) %></span></span>
        <span class="text-base-content/50"><%= t("credit_cards.limit") %> <span class="font-medium tabular-nums text-base-content/70"><%= brl(credit_card.credit_limit_cents) %></span></span>
      </div>
      <div class="mt-1.5 h-2 w-full overflow-hidden rounded-full bg-base-200">
        <div class="h-full rounded-full <%= bar %>" style="width: <%= (ratio * 100).round %>%"></div>
      </div>
      <p class="mt-1.5 text-right text-xs text-base-content/50"><%= t("credit_cards.available") %> <span class="font-semibold text-success tabular-nums"><%= brl(credit_card.available_cents) %></span></p>
    </div>
  <% else %>
    <p class="mt-2 text-xs text-base-content/40"><%= t("credit_cards.no_limit") %></p>
  <% end %>
</div>
