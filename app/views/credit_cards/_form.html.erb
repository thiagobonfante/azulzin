<%# locals: credit_card %>
<%# The create form (index/onboarding) posts to a Turbo Stream and resets on success; the
    full-page edit form (billing config) PATCHes and redirects, so it skips form-reset. %>
<%= form_with model: credit_card,
      url: (credit_card.persisted? ? credit_card_path(credit_card) : credit_cards_path),
      id: "credit_card_form",
      data: (credit_card.persisted? ? {} : { controller: "form-reset", action: "turbo:submit-end->form-reset#reset" }),
      class: "flex flex-col gap-4" do |f| %>
  <div id="credit_card_form_errors">
    <%= render "credit_cards/form_errors", record: credit_card %>
  </div>

  <%# Carry the hub's return context (token, never a URL) through the edit round-trip. %>
  <% if params[:return_to].present? %>
    <%= hidden_field_tag :return_to, params[:return_to] %>
    <%= hidden_field_tag :month, params[:month] %>
  <% end %>

  <%= render "shared/institution_select", form: f, institutions: Institution.for_cards %>

  <div class="form-control">
    <%= f.label :nickname, t("credit_cards.nickname"), class: "mb-1 block text-sm font-medium" %>
    <%= f.text_field :nickname, placeholder: t("credit_cards.nickname_placeholder"), class: "input input-bordered w-full" %>
  </div>

  <%# Physical vs virtual — identification only, no billing effect. %>
  <div class="form-control">
    <label class="mb-1 block text-sm font-medium"><%= t("credit_cards.card_type") %></label>
    <div class="join">
      <% CreditCard.card_types.each_key do |ct| %>
        <label class="join-item btn btn-sm font-normal has-checked:btn-primary">
          <%= f.radio_button :card_type, ct, class: "hidden", checked: (credit_card.card_type == ct) %>
          <%= t("credit_cards.card_types.#{ct}") %>
        </label>
      <% end %>
    </div>
  </div>

  <%# ── Billing config (R2) — primary fields; R11 correctness depends on them ─────────── %>
  <% offset = credit_card.closing_offset_days || 7 %>
  <div class="grid gap-4 sm:grid-cols-2" data-controller="billing-hint"
       data-billing-hint-template-value="<%= t('credit_cards.best_purchase_day', day: '{day}') %>">
    <div class="form-control">
      <%= f.label :bill_due_day, t("credit_cards.bill_due_day"), class: "mb-1 block text-sm font-medium" %>
      <%= f.select :bill_due_day, (1..31).to_a, { include_blank: t("credit_cards.bill_due_day_unknown") },
            class: "select select-bordered w-full",
            data: { billing_hint_target: "dueDay", action: "billing-hint#update" } %>
    </div>
    <div class="form-control">
      <%= f.label :closing_offset_days, t("credit_cards.closing_offset_days"), class: "mb-1 block text-sm font-medium" %>
      <%= f.select :closing_offset_days,
            (0..28).map { |n| [ t("credit_cards.closing_offset_option", count: n), n ] },
            { selected: offset },
            class: "select select-bordered w-full",
            data: { billing_hint_target: "offset", action: "billing-hint#update" } %>
    </div>
    <div class="text-xs text-base-content/50 sm:col-span-2">
      <p><%= t("credit_cards.billing_explainer", offset: offset) %></p>
      <p data-billing-hint-target="hint"
         class="mt-1 font-medium text-primary <%= "hidden" unless credit_card.billing_configured? %>">
        <%= t("credit_cards.best_purchase_day", day: (credit_card.closing_date(Date.current.beginning_of_month) + 1).day) if credit_card.billing_configured? %>
      </p>
      <% if credit_card.persisted? %>
        <p class="mt-1"><%= t("credit_cards.billing_hint") %></p>
      <% end %>
    </div>
  </div>

  <%# Optional details — legacy fallback for unconfigured cards; nothing here is required. %>
  <details class="group">
    <summary class="flex cursor-pointer list-none items-center gap-1 text-sm font-medium text-primary">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
      <%= t("credit_cards.optional_details") %>
    </summary>
    <div class="mt-3 grid gap-4 sm:grid-cols-2">
      <div class="form-control">
        <%= f.label :last4, t("credit_cards.last4"), class: "mb-1 block text-sm font-medium" %>
        <%= f.text_field :last4, inputmode: "numeric", maxlength: 4,
              placeholder: t("credit_cards.last4_placeholder"), class: "input input-bordered w-full" %>
      </div>
      <div class="form-control">
        <%= f.label :credit_limit_reais, t("credit_cards.limit"), class: "mb-1 block text-sm font-medium" %>
        <label class="input input-bordered flex w-full items-center gap-2">
          <span class="text-base-content/50"><%= t("money.symbol") %></span>
          <%= f.text_field :credit_limit_reais, inputmode: "decimal", placeholder: "0,00", class: "grow" %>
        </label>
      </div>
      <%# Legacy fallback (02 §6): only shown while the card has no billing config — configured
          cards derive the bill from posted rows, so the manual snapshot is hidden. %>
      <% unless credit_card.billing_configured? %>
        <div class="form-control">
          <%= f.label :current_bill_reais, t("credit_cards.current_bill"), class: "mb-1 block text-sm font-medium" %>
          <label class="input input-bordered flex w-full items-center gap-2">
            <span class="text-base-content/50"><%= t("money.symbol") %></span>
            <%= f.text_field :current_bill_reais, inputmode: "decimal", placeholder: "0,00", class: "grow" %>
          </label>
          <span class="mt-1 text-xs text-base-content/50"><%= t("credit_cards.current_bill_hint") %></span>
        </div>
      <% end %>
    </div>
  </details>

  <%# Edit footer: attribution + the (dangerous) remove on the left, save on the right. The
      remove is a turbo_method link, not a button_to — a nested <form> here would be invalid. %>
  <div class="flex items-center justify-between gap-2">
    <div class="flex items-center gap-2">
      <% if credit_card.persisted? %>
        <%= link_to t("credit_cards.remove"), credit_card_path(credit_card),
              data: { turbo_method: :delete, turbo_confirm: t("credit_cards.confirm_remove") },
              class: "btn btn-ghost btn-sm text-error" %>
      <% end %>
    </div>
    <%= f.submit (credit_card.persisted? ? t("credit_cards.save") : t("credit_cards.add")), class: "btn btn-primary btn-sm" %>
  </div>
<% end %>
