<% if @credit_card.persisted? %>
  <%= turbo_stream.remove "credit_cards_empty" %>
  <%= turbo_stream.append "credit_cards_list", partial: "credit_cards/credit_card", locals: { credit_card: @credit_card } %>
  <%= turbo_stream.replace "credit_card_form", partial: "credit_cards/form", locals: { credit_card: CreditCard.new } %>
<% else %>
  <%= turbo_stream.replace "credit_card_form", partial: "credit_cards/form", locals: { credit_card: @credit_card } %>
<% end %>
