<% checked = proposal["confidence"].to_f >= 0.8 %>
<% pid = proposal["pid"] %>
<div class="rounded-box border border-base-300/70 bg-base-100 p-4 shadow-sm">
  <div class="flex items-start gap-3">
    <%= check_box_tag "check[#{pid}]", "1", checked, id: "check_#{pid}", class: "checkbox checkbox-sm mt-1" %>
    <div class="min-w-0 flex-1">
      <div class="flex flex-wrap items-center gap-2">
        <%= text_field_tag "edits[#{pid}][name]", proposal_name(proposal),
                           class: "input input-bordered input-sm", "aria-labelledby": "check_#{pid}" %>
        <% if (institutions = proposal_institutions(proposal)) %>
          <div class="w-full sm:max-w-xs">
            <%= render "shared/institution_select",
                       name: "edits[#{pid}][institution_code]",
                       selected: proposal.dig("payload", "institution_code"),
                       institutions: institutions, value_method: :code, label: false %>
          </div>
        <% end %>
        <% if proposal["kind"] == "income" %>
          <label class="input input-bordered input-sm flex items-center gap-1">
            <span class="text-base-content/50"><%= t("money.symbol") %></span>
            <%= text_field_tag "edits[#{pid}][amount_reais]", reais_value(proposal.dig("payload", "amount_cents")),
                               inputmode: "decimal", class: "w-24 border-0 bg-transparent p-0 focus:outline-none",
                               data: { controller: "money-mask", money_mask_cents_value: true, action: "input->money-mask#format" } %>
          </label>
        <% elsif (summary = proposal_summary(proposal)) %>
          <span class="text-sm text-base-content/70"><%= summary %></span>
        <% end %>
        <% if (category = proposal_category(proposal)) %>
          <span class="badge badge-ghost badge-sm gap-1" title="<%= t("document_imports.review.category_chip_title") %>">
            <span class="h-2 w-2 rounded-full" style="background-color: <%= category.display_color %>"></span>
            <%= category.name %>
          </span>
        <% end %>
        <% unless checked %>
          <span class="badge badge-warning badge-sm"><%= t("document_imports.review.check_badge") %></span>
        <% end %>
      </div>
      <p class="mt-1 text-xs text-base-content/50"><%= proposal_evidence(proposal) %></p>
    </div>
    <%# Submit button of the OUTER review form — a button_to here would nest a <form> inside it,
        which browsers flatten, leaking hidden discard params into every submit. %>
    <%= button_tag t("document_imports.review.discard"), name: "discard", value: pid,
                   formnovalidate: true, class: "btn btn-ghost btn-xs shrink-0" %>
  </div>
</div>
