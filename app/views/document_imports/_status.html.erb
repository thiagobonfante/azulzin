<%= turbo_frame_tag :import_status do %>
  <% if imports.any? %>
    <% busy = imports.any? { %w[uploaded processing].include?(it.status) } %>
    <div class="flex flex-col gap-2">
      <%= render partial: "document_imports/import", collection: imports, as: :import %>
    </div>
    <% if imports.any? { it.status == "extracted" } %>
      <div class="mt-3">
        <% if busy %>
          <button type="button" class="btn btn-primary btn-sm" disabled>
            <%= t("document_imports.review_button") %>
          </button>
        <% else %>
          <%= link_to t("document_imports.review_button"), review_document_imports_path,
                      class: "btn btn-primary btn-sm", data: { turbo_frame: "_top" } %>
        <% end %>
      </div>
    <% end %>
  <% end %>
<% end %>
