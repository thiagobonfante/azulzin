<%# locals: goal — an active goal card on the index. %>
<% progress = Goals::Progress.new(goal) %>
<% actual = progress.actual_cents %>
<% check = goal.checks.latest_first.first %>
<% status = check&.status || "insufficient_data" %>
<%= link_to goal_path(goal), class: "block rounded-box border border-base-300/70 bg-base-100 p-4 shadow-sm hover:border-primary/40" do %>
  <div class="flex items-center justify-between gap-2">
    <span class="font-semibold"><%= goal.name %></span>
    <% if check %>
      <span class="badge <%= goal_pace_badge_class(status) %> badge-sm"><%= t("goals.pace.#{status}") %></span>
    <% end %>
  </div>
  <% if goal.purchase? %>
    <div class="mt-3 h-2 w-full overflow-hidden rounded-full bg-base-200">
      <div class="h-full rounded-full <%= goal_bar_class(status) %>" style="width: <%= goal_percent(actual, goal.target_cents) %>%"></div>
    </div>
    <p class="mt-1.5 text-right text-xs tabular-nums text-base-content/60">
      <%= t("goals.show.progress_line", actual: brl_whole(actual, mode: :floor), target: brl_whole(goal.target_cents)) %>
    </p>
  <% else %>
    <p class="mt-2 text-sm tabular-nums text-base-content/60"><%= t("goals.show.monthly_target", amount: brl_whole(goal.monthly_target_cents)) %></p>
  <% end %>
<% end %>
