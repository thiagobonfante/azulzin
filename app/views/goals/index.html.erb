<% content_for :title, t("goals.index.meta_title") %>
<% at_cap = @active.size >= Goal::MAX_ACTIVE %>

<header class="mb-6 flex items-center justify-between gap-3">
  <div>
    <h1 data-native-dup class="font-display text-2xl font-extrabold tracking-tight"><%= t("goals.index.title") %></h1>
    <p class="text-sm text-base-content/60"><%= t("goals.index.subtitle") %></p>
  </div>
  <% unless at_cap %>
    <%= link_to t("goals.index.new"), new_goal_path, class: "btn btn-primary btn-sm" %>
  <% end %>
</header>

<% if at_cap %>
  <div class="mb-6 rounded-box border border-base-300/70 bg-base-100 p-4 text-sm text-base-content/60">
    <%= t("goals.states.limit_reached") %>
  </div>
<% end %>

<% if @active.any? %>
  <div class="flex flex-col gap-4"><%= render @active %></div>
<% else %>
  <%= render "goals/empty" %>
<% end %>

<% if @closed.any? %>
  <section class="mt-10">
    <h2 class="mb-3 font-display text-lg font-bold text-base-content/60"><%= t("goals.index.closed_title") %></h2>
    <ul class="flex flex-col gap-2">
      <% @closed.each do |goal| %>
        <li>
          <%= link_to goal_path(goal), class: "flex items-center justify-between rounded-box border border-base-300/70 bg-base-100/60 px-4 py-3 text-sm shadow-sm hover:border-primary/40" do %>
            <span class="text-base-content/70"><%= goal.name %></span>
            <span class="badge badge-ghost badge-sm"><%= t("goals.status.#{goal.status}") %></span>
          <% end %>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>
