<% content_for :title, @goal.name %>
<% actual = @progress.actual_cents %>
<% latest = @goal.checks.latest_first.first %>
<% pace_status = latest&.status || "insufficient_data" %>

<header class="mb-6 flex items-center justify-between gap-3">
  <div class="flex items-center gap-2">
    <h1 class="font-display text-2xl font-extrabold tracking-tight"><%= @goal.name %></h1>
    <span class="badge <%= @goal.achieved? ? "badge-primary" : "badge-ghost" %> badge-sm"><%= t("goals.status.#{@goal.status}") %></span>
  </div>
  <%= link_to t("goals.show.back"), goals_path, class: "btn btn-ghost btn-sm" %>
</header>

<% if @goal.achieved? %>
  <section class="mb-6 rounded-box border border-primary/40 bg-primary/5 p-6 text-center">
    <p class="text-4xl">🎉</p>
    <h2 class="mt-2 font-display text-xl font-extrabold text-primary"><%= t("goals.show.achieved_title") %></h2>
    <p class="mt-1 text-sm text-base-content/70"><%= t("goals.show.achieved_body", amount: brl_whole(actual, mode: :floor)) %></p>
    <%= link_to t("goals.show.next_goal"), new_goal_path, class: "btn btn-primary btn-sm mt-4" %>
  </section>
<% end %>

<%# ── Progress ────────────────────────────────────────────────────────── %>
<section class="mb-6 rounded-box border border-base-300/70 bg-base-100 p-5 shadow-sm">
  <div class="flex items-baseline justify-between">
    <p class="font-display text-2xl font-extrabold tabular-nums text-primary"><%= brl_whole(actual, mode: :floor) %></p>
    <% if @goal.purchase? %>
      <p class="text-sm text-base-content/60"><%= t("goals.show.saved_of", target: brl_whole(@goal.target_cents)) %></p>
    <% else %>
      <p class="text-sm text-base-content/60"><%= t("goals.show.monthly_target", amount: brl_whole(@goal.monthly_target_cents)) %></p>
    <% end %>
  </div>
  <% if @goal.purchase? %>
    <div class="mt-3 h-2.5 w-full overflow-hidden rounded-full bg-base-200">
      <div class="h-full rounded-full <%= goal_bar_class(pace_status) %>" style="width: <%= goal_percent(actual, @goal.target_cents) %>%"></div>
    </div>
  <% end %>
  <% unless @goal.achieved? %>
    <div class="mt-3 flex items-center gap-2">
      <span class="badge <%= goal_pace_badge_class(pace_status) %> badge-sm"><%= t("goals.pace.#{pace_status}") %></span>
      <%# Pre-start gap month (round 3 decision 3): "começa em <mês>" instead of "esperado R$ 0". %>
      <% if @goal.starts_on && Date.current.in_time_zone(Goals::TZ).to_date < @goal.starts_on %>
        <span class="text-xs text-base-content/50"><%= t("goals.show.starts_in", month: l(@goal.starts_on, format: :month_year)) %></span>
      <% else %>
        <span class="text-xs text-base-content/50"><%= t("goals.show.expected", amount: brl_whole(@progress.expected_cents)) %></span>
      <% end %>
    </div>
    <%# Derived forecast (round 3 decision 6) — moves earlier by itself after a speed-up. %>
    <% if @goal.purchase? && (projected = @progress.projected_done_on) %>
      <p class="mt-2 text-xs text-base-content/50"><%= t("goals.show.projected_line", month: l(projected, format: :month_year)) %></p>
    <% end %>
  <% end %>
</section>

<%# ── This month's parcel — the commitment IS how you save (round 3 P3) ── %>
<% unless @goal.achieved? %>
  <% if (commitment = @goal.savings_commitment) %>
    <% month = Date.current.in_time_zone(Goals::TZ).to_date.beginning_of_month %>
    <%# Pre-start gap month: the first occurrence is next month (round 3 decision 3) — the
        progress card already says "começa em <mês>", so no dead Pagar button here. %>
    <% if commitment.active_in?(month) %>
      <% occurrence = CommitmentOccurrence.new(commitment, month) %>
      <div class="mb-6 flex flex-wrap items-center gap-3">
        <% if (payment = occurrence.payment) %>
          <span class="text-sm text-base-content/70"><%= t("goals.show.parcel_paid", amount: brl_whole(payment.amount_cents, mode: :floor), date: l(payment.occurred_on, format: :weekday_day)) %></span>
        <% else %>
          <span class="text-sm font-medium"><%= t("goals.show.parcel_due", amount: brl_whole(commitment.amount_cents)) %></span>
          <%# Force html: pay.turbo_stream targets hub/commitments ids absent on this page. %>
          <%= button_to t("commitments.occurrences.mark_paid"), pay_commitment_occurrence_path(occurrence, from: "goal"),
                method: :patch, form: { data: { turbo: false } }, class: "btn btn-primary btn-sm" %>
        <% end %>
        <%= link_to t("goals.show.view_commitment"), commitment_path(commitment), class: "link-hover link text-xs text-base-content/55" %>
      </div>
    <% end %>
  <% else %>
    <%# Legacy unlinked goal (pre round-3 activation) — no parcel to pay from here. %>
    <div class="mb-6 flex flex-wrap items-center gap-3">
      <%= link_to t("app.nav.commitments"), commitments_path, class: "btn btn-ghost btn-sm" %>
      <% unless @goal.bank_account_id %>
        <span class="text-xs text-base-content/55"><%= t("goals.show.no_caixinha_nudge") %></span>
      <% end %>
    </div>
  <% end %>
<% end %>

<%# ── Speed-up (round 3 decision 6): parcel paid + sobra ≥ 20% of it ──── %>
<% if @speed_up %>
  <section class="mb-6 rounded-box border border-primary/40 bg-primary/5 p-5">
    <h2 class="font-display text-lg font-bold"><%= t("goals.show.speed_up_title") %></h2>
    <p class="mt-1 text-sm text-base-content/70"><%= t("goals.show.speed_up_body", amount: brl_whole(@speed_up.sobra_cents, mode: :floor)) %></p>
    <%= form_with url: contribute_goal_path(@goal), method: :post, class: "mt-3 flex flex-wrap items-center gap-2" do %>
      <label class="input input-bordered input-sm flex w-36 items-center gap-2">
        <span class="text-base-content/50"><%= t("money.symbol") %></span>
        <%= text_field_tag :amount_reais, nil, inputmode: "numeric", placeholder: "0", class: "min-w-0 grow",
              data: { controller: "money-mask", action: "input->money-mask#format" },
              aria: { label: t("goals.show.speed_up_title") } %>
      </label>
      <%= submit_tag t("goals.show.speed_up_submit"), class: "btn btn-primary btn-sm" %>
    <% end %>
    <p class="mt-2 text-xs text-base-content/50"><%= t("goals.show.speed_up_hint") %></p>
  </section>
<% end %>

<%# ── Trim map ────────────────────────────────────────────────────────── %>
<% cuts = @goal.plan["cuts"] || [] %>
<% if cuts.any? %>
  <section class="mb-6 rounded-box border border-base-300/70 bg-base-100 p-5 shadow-sm">
    <h2 class="mb-3 font-semibold"><%= t("goals.show.trim_map_title") %></h2>
    <ul class="flex flex-col gap-2 text-sm">
      <% cuts.each do |cut| %>
        <li class="flex justify-between">
          <span class="text-base-content/70"><%= cut["name"] %></span>
          <span class="tabular-nums text-base-content/60"><%= t("goals.show.cap_line", cap: brl_whole(cut["cap_cents"]), baseline: brl_whole(cut["baseline_cents"])) %></span>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>

<%# ── Contribution history ────────────────────────────────────────────── %>
<% contributions = @progress.contributions.limit(24) %>
<% if contributions.any? %>
  <section class="mb-6 rounded-box border border-base-300/70 bg-base-100 p-5 shadow-sm">
    <h2 class="mb-3 font-semibold"><%= t("goals.show.contributions_title") %></h2>
    <ul class="divide-y divide-base-200 text-sm">
      <% contributions.each do |txn| %>
        <li class="flex items-center justify-between py-2">
          <span class="text-base-content/60"><%= l(txn.occurred_on, format: :weekday_day) %></span>
          <span class="font-medium tabular-nums text-primary"><%= brl_whole(txn.amount_cents, mode: :floor) %></span>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>

<%# ── Weekly check timeline ───────────────────────────────────────────── %>
<% checks = @goal.checks.latest_first.limit(8) %>
<% if checks.any? %>
  <section class="mb-6 rounded-box border border-base-300/70 bg-base-100 p-5 shadow-sm">
    <h2 class="mb-3 font-semibold"><%= t("goals.show.checks_title") %></h2>
    <ul class="flex flex-col gap-2 text-sm">
      <% checks.each do |check| %>
        <li class="flex items-center justify-between">
          <span class="text-base-content/60"><%= l(check.period_start, format: :weekday_day) %></span>
          <span class="badge <%= goal_pace_badge_class(check.status) %> badge-sm"><%= t("goals.pace.#{check.status}") %></span>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>

<% unless @goal.achieved? %>
  <div class="flex items-center gap-3">
    <%= button_to t("goals.show.abandon"), abandon_goal_path(@goal), method: :patch,
          form: { data: { turbo_confirm: t("goals.show.abandon_confirm") } }, class: "btn btn-ghost btn-sm text-error" %>
    <span class="text-xs text-base-content/45"><%= t("goals.show.abandoned_note") %></span>
  </div>
<% end %>
