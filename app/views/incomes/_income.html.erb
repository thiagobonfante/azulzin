<%# locals: income %>
<div id="<%= dom_id(income) %>" class="flex items-center gap-3 rounded-box border border-base-300/70 bg-base-100 p-3 shadow-sm">
  <span class="inline-grid h-9 w-9 shrink-0 place-items-center rounded-full bg-success/15 text-success">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
  </span>
  <div class="min-w-0 flex-1">
    <p class="truncate text-sm font-semibold"><%= income.name %></p>
    <p class="truncate text-xs text-base-content/50">
      <%= income_schedule_label(income) %> · <%= t("incomes.row.into_account", account: income.bank_account.display_name) %>
    </p>
  </div>
  <%= render "shared/attribution", record: income %>
  <span class="shrink-0 font-display text-sm font-bold tabular-nums text-success"><%= brl(income.amount_cents) %></span>
  <%= link_to edit_income_path(income),
        class: "btn btn-ghost btn-sm btn-square text-base-content/40 hover:text-primary",
        aria: { label: t("incomes.edit_title") } do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zM19.5 7.125L16.875 4.5" /></svg>
  <% end %>
  <%= button_to income_path(income), method: :delete,
        class: "btn btn-ghost btn-sm btn-square text-base-content/40 hover:text-error",
        form: { data: { turbo_confirm: t("incomes.confirm_remove") } },
        aria: { label: t("incomes.remove") } do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" /></svg>
  <% end %>
</div>
