<%# locals: income — the name block links to edit (a pen fades in on hover); attribution +
    remove live on the edit page. The name column keeps a minimum width, so on narrow screens
    the amount wraps to its own right-aligned line instead of crushing it. %>
<div id="<%= dom_id(income) %>" class="flex flex-wrap items-center gap-x-3 gap-y-1.5 rounded-box border border-base-300/70 bg-base-100 p-3 shadow-sm">
  <%= link_to edit_income_path(income), class: "group flex min-w-48 flex-1 items-center gap-3",
        aria: { label: t("incomes.edit_title") } do %>
    <span class="inline-grid h-9 w-9 shrink-0 place-items-center rounded-full bg-success/15 text-success">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
    </span>
    <div class="min-w-0 flex-1">
      <p class="flex items-center gap-1.5 text-sm font-semibold">
        <span class="truncate"><%= income.name %></span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0 opacity-0 transition-opacity group-hover:opacity-50 group-focus-visible:opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zM19.5 7.125L16.875 4.5" /></svg>
      </p>
      <p class="truncate text-xs text-base-content/50">
        <%= income_schedule_label(income) %> · <%= t("incomes.row.into_account", account: income.bank_account.display_name) %>
      </p>
    </div>
  <% end %>
  <span class="ml-auto shrink-0 font-display text-sm font-bold tabular-nums text-success"><%= brl(income.amount_cents) %></span>
</div>
