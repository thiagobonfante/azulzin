<% content_for :title, t("incomes.edit_title") %>

<header class="mb-6">
  <%= link_to incomes_path, class: "mb-2 inline-flex items-center gap-1 text-sm text-base-content/50 hover:text-base-content" do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
    <%= t("app.nav.incomes") %>
  <% end %>
  <h1 class="font-display text-2xl font-extrabold tracking-tight"><%= t("incomes.edit_title") %></h1>
  <p class="text-sm text-base-content/60"><%= @income.name %></p>
</header>

<div class="max-w-xl">
  <div class="rounded-box border border-base-300/70 bg-base-100 p-5 shadow-sm">
    <%= render "incomes/form", income: @income %>
  </div>
</div>
