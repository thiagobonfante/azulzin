<title><%= content_for(:title) || t("layout.title") %></title>
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="application-name" content="azulzin">
<meta name="mobile-web-app-capable" content="yes">
<meta name="theme-color" content="oklch(58% 0.17 254)">
<%= csrf_meta_tags %>
<%= csp_meta_tag %>

<%# PWA: manifest + service worker are served on the app host only (see routes on_app). %>
<% if on_app_host? %>
  <%= tag.link rel: "manifest", href: pwa_manifest_path %>
<% end %>

<%= yield :head %>

<%# Favicons. The ?v= busts the year-long edge cache (Cloudflare) when an icon changes —
    bump it on every icon update. /favicon.ico covers browsers/contexts that ignore the link
    tags below (Safari, bookmarks, the browser's default request). %>
<link rel="icon" href="/favicon.ico?v=2" sizes="any">
<link rel="icon" href="/icon.svg?v=2" type="image/svg+xml">
<link rel="icon" href="/icon.png?v=2" type="image/png">
<link rel="apple-touch-icon" href="/icon.png?v=2">

<link rel="preload" href="/fonts/bricolage-grotesque-variable.woff2" as="font" type="font/woff2" crossorigin>
<link rel="preload" href="/fonts/inter-variable.woff2" as="font" type="font/woff2" crossorigin>

<%# Includes all stylesheet files in app/assets/stylesheets %>
<%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
<%= javascript_importmap_tags %>
