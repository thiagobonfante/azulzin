<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <%= render "layouts/meta" %>
  </head>

  <body class="min-h-screen bg-base-200 text-base-content font-sans antialiased">
    <div class="drawer lg:drawer-open">
      <input id="app-drawer" type="checkbox" class="drawer-toggle" />

      <%# ── Content column ─────────────────────────────────────────────── %>
      <div class="drawer-content flex min-h-screen flex-col">
        <%# Mobile top bar (sidebar becomes a drawer below lg) %>
        <header class="sticky top-0 z-20 flex items-center gap-3 border-b border-base-300/60 bg-base-100/80 px-4 py-3 backdrop-blur lg:hidden">
          <label for="app-drawer" class="btn btn-square btn-ghost btn-sm" aria-label="<%= t("app.nav.open_menu") %>">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
            </svg>
          </label>
          <span class="font-display text-lg font-extrabold tracking-tight lowercase">azulzin</span>
        </header>

        <main class="flex-1 px-4 py-6 sm:px-6 lg:px-10 lg:py-10">
          <div class="mx-auto w-full max-w-5xl">
            <% if flash.any? %>
              <div class="mb-6"><%= render "shared/flash" %></div>
            <% end %>
            <%= yield %>
          </div>
        </main>
      </div>

      <%# ── Sidebar ────────────────────────────────────────────────────── %>
      <div class="drawer-side z-30">
        <label for="app-drawer" aria-label="<%= t("app.nav.close_menu") %>" class="drawer-overlay"></label>
        <aside class="flex min-h-full w-64 flex-col border-r border-base-300/60 bg-base-100 px-4 py-5">
          <%= link_to dashboard_path, class: "flex items-center gap-2 px-2" do %>
            <span class="inline-grid h-8 w-8 place-items-center rounded-xl bg-primary text-primary-content shadow-sm">
              <span class="h-3 w-3 rounded-full bg-primary-content/90"></span>
            </span>
            <span class="font-display text-xl font-extrabold tracking-tight lowercase">azulzin</span>
          <% end %>

          <nav class="mt-8 flex-1">
            <ul class="flex flex-col gap-1">
              <li>
                <%= sidebar_link t("app.nav.dashboard"), dashboard_path, active: current_page?(dashboard_path) do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25A2.25 2.25 0 018.25 10.5H6A2.25 2.25 0 013.75 8.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 018.25 20.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25A2.25 2.25 0 0113.5 8.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" /></svg>
                <% end %>
              </li>
              <li>
                <%= sidebar_link t("app.nav.accounts"), bank_accounts_path, active: current_page?(bank_accounts_path) do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3l9 4.5H3L12 3zM4.5 10.5v6M9 10.5v6m6-6v6m4.5-6v6M3 20.25h18" /></svg>
                <% end %>
              </li>
              <li>
                <%= sidebar_link t("app.nav.cards"), credit_cards_path, active: current_page?(credit_cards_path) do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9V6.75A2.25 2.25 0 014.5 4.5h15a2.25 2.25 0 012.25 2.25v10.5A2.25 2.25 0 0119.5 19.5h-15A2.25 2.25 0 012.25 17.25V9z" /></svg>
                <% end %>
              </li>
              <li>
                <%= sidebar_link t("app.nav.inbox"), transactions_path, active: current_page?(transactions_path) do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 13.5h3.86a2.25 2.25 0 012.012 1.244l.256.512a2.25 2.25 0 002.013 1.244h3.218a2.25 2.25 0 002.013-1.244l.256-.512a2.25 2.25 0 012.013-1.244h3.859m-19.5.338V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18v-4.162c0-.224-.034-.447-.1-.661L19.24 5.338a2.25 2.25 0 00-2.15-1.588H6.911a2.25 2.25 0 00-2.15 1.588L2.35 13.177a2.25 2.25 0 00-.1.661z" /></svg>
                <% end %>
              </li>
              <% if Current.user.admin? %>
                <li>
                  <%= sidebar_link t("app.nav.admin"), admin_whatsapp_connection_path, active: current_page?(admin_whatsapp_connection_path) do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
                  <% end %>
                </li>
              <% end %>
            </ul>
          </nav>

          <%# User menu %>
          <% initial = (Current.user.name.to_s.strip.first.presence || Current.user.email_address.first).upcase %>
          <div class="border-t border-base-300/60 pt-3">
            <div class="dropdown dropdown-top w-full">
              <div tabindex="0" role="button" class="flex w-full items-center gap-3 rounded-box px-2 py-2 hover:bg-base-200">
                <span class="inline-grid h-9 w-9 shrink-0 place-items-center rounded-full bg-primary/15 text-sm font-semibold text-primary"><%= initial %></span>
                <span class="min-w-0 flex-1 text-left">
                  <span class="block truncate text-sm font-medium"><%= Current.user.name.presence || Current.user.email_address %></span>
                  <span class="block truncate text-xs text-base-content/50"><%= Current.user.email_address %></span>
                </span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-base-content/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15L12 18.75 15.75 15M8.25 9L12 5.25 15.75 9" /></svg>
              </div>
              <ul tabindex="0" class="dropdown-content menu z-40 mb-2 w-52 rounded-box border border-base-300/60 bg-base-100 p-2 shadow-lg">
                <li><%= button_to t("layout.nav.sign_out"), session_path, method: :delete, class: "w-full text-left" %></li>
              </ul>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </body>
</html>
