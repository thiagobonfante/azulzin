<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <%= render "layouts/meta" %>
  </head>

  <body class="min-h-screen flex flex-col overflow-x-hidden bg-base-200 text-base-content font-sans antialiased">
    <header class="sticky top-0 z-30 border-b border-base-300/60 bg-base-100/80 backdrop-blur">
      <div class="container mx-auto flex items-center justify-between gap-4 px-5 py-3">
        <%= link_to root_path, class: "flex items-center gap-2 group" do %>
          <span class="inline-grid h-8 w-8 place-items-center rounded-xl bg-primary text-primary-content shadow-sm transition-transform group-hover:-rotate-6">
            <span class="h-3 w-3 rounded-full bg-primary-content/90"></span>
          </span>
          <span class="font-display text-xl font-extrabold tracking-tight lowercase">azulzin</span>
        <% end %>
        <nav class="flex items-center gap-1 sm:gap-2">
          <% if authenticated? %>
            <%= button_to t("layout.nav.sign_out"), session_path, method: :delete, class: "btn btn-ghost btn-sm" %>
          <% else %>
            <%= link_to t("layout.nav.sign_in"), app_url(new_session_path), class: "btn btn-ghost btn-sm hidden sm:inline-flex" %>
            <%= link_to t("layout.nav.get_started"), app_url(new_registration_path), class: "btn btn-primary btn-sm" %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <% if flash.any? %>
        <div class="container mx-auto px-5 pt-4">
          <%= render "shared/flash" %>
        </div>
      <% end %>
      <%= yield %>
    </main>

    <footer class="border-t border-base-300/60">
      <div class="container mx-auto flex flex-col items-center justify-between gap-3 px-5 py-6 text-sm text-base-content/60 sm:flex-row">
        <span class="font-display font-semibold lowercase">azulzin</span>
        <span><%= t("layout.footer.tagline") %></span>
        <%# Language switcher hidden while the UI is pinned to pt-BR
            (ApplicationController#resolve_locale). Restore this block from git to
            bring it back when en-US is re-enabled. %>
      </div>
    </footer>
  </body>
</html>
