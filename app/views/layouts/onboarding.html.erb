<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <%= render "layouts/meta" %>
  </head>

  <body class="min-h-screen bg-base-200 text-base-content font-sans antialiased">
    <div class="mx-auto flex min-h-screen w-full max-w-2xl flex-col px-4 py-8 sm:py-12">
      <header class="flex items-center justify-between">
        <span class="flex items-center gap-2">
          <span class="inline-grid h-8 w-8 place-items-center rounded-xl bg-primary text-primary-content shadow-sm">
            <span class="h-3 w-3 rounded-full bg-primary-content/90"></span>
          </span>
          <span class="font-display text-xl font-extrabold tracking-tight lowercase">azulzin</span>
        </span>
        <%= button_to t("layout.nav.sign_out"), session_path, method: :delete, class: "btn btn-ghost btn-sm" %>
      </header>

      <% if @step %>
        <%= render "onboarding/progress", current_step: @step %>
      <% end %>

      <main class="mt-8 flex-1">
        <% if flash.any? %>
          <div class="mb-6"><%= render "shared/flash" %></div>
        <% end %>
        <%= yield %>
      </main>
    </div>
  </body>
</html>
