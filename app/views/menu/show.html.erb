<section class="mx-auto w-full max-w-2xl">
  <h1 data-native-dup class="font-display text-2xl font-extrabold tracking-tight"><%= t(".title") %></h1>

  <div class="mt-6 space-y-4">
    <ul class="divide-y divide-base-300/60 overflow-hidden rounded-box border border-base-300/60 bg-base-100">
      <%= render "row", label: t("app.nav.goals"),       path: goals_path,         icon: icons[:goals] %>
      <%= render "row", label: t("app.nav.commitments"), path: commitments_path,   icon: icons[:commitments] %>
      <%= render "row", label: t("app.nav.accounts"),    path: bank_accounts_path, icon: icons[:accounts] %>
      <%= render "row", label: t("app.nav.incomes"),     path: incomes_path,       icon: icons[:incomes] %>
      <%= render "row", label: t("app.nav.cards"),       path: credit_cards_path,  icon: icons[:cards] %>
      <%= render "row", label: t("app.nav.categories"),  path: categories_path,    icon: icons[:categories] %>
    </ul>

    <ul class="divide-y divide-base-300/60 overflow-hidden rounded-box border border-base-300/60 bg-base-100">
      <%= render "row", label: t("notification_preferences.show.title"), path: notification_preferences_path, icon: icons[:alerts] %>
      <%= render "row", label: t("exports.new.title"),                   path: new_export_path,               icon: icons[:export] %>
      <%= render "row", label: t("layout.nav.account_settings"),         path: account_path,                  icon: icons[:members] %>
      <% if Current.user.admin? %>
        <%= render "row", label: t("app.nav.admin"), path: admin_whatsapp_connection_path, icon: icons[:admin] %>
      <% end %>
    </ul>

    <div class="overflow-hidden rounded-box border border-base-300/60 bg-base-100">
      <%# turbo_action replace: the sign-in landing REPLACES this menu in the native
          stack — no back arrow to a dead signed-out menu snapshot. %>
      <%= button_to session_path, method: :delete, form: { data: { turbo_action: "replace" } },
            class: "flex w-full items-center gap-3 px-4 py-3.5 text-left text-error transition-colors hover:bg-error/10" do %>
        <span class="inline-grid h-9 w-9 shrink-0 place-items-center rounded-xl bg-error/10">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3-3H9m12 0l-3-3m3 3l-3 3" /></svg>
        </span>
        <span class="flex-1 font-medium"><%= t("layout.nav.sign_out") %></span>
      <% end %>
    </div>
  </div>
</section>
