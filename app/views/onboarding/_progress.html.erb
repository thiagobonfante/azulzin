<%# locals: current_step %>
<% steps = OnboardingController::STEPS %>
<% current_index = steps.index(current_step).to_i %>
<ol class="mt-8 flex items-center">
  <% steps.each_with_index do |step, i| %>
    <% state = i < current_index ? :done : (i == current_index ? :current : :upcoming) %>
    <li class="flex items-center <%= "flex-1" unless i == steps.size - 1 %>">
      <span class="inline-grid h-8 w-8 shrink-0 place-items-center rounded-full text-sm font-semibold <%= { done: "bg-primary text-primary-content", current: "bg-primary text-primary-content ring-4 ring-primary/20", upcoming: "bg-base-300 text-base-content/50" }[state] %>">
        <% if state == :done %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
        <% else %>
          <%= i + 1 %>
        <% end %>
      </span>
      <span class="ml-2 hidden text-sm font-medium sm:block <%= "text-base-content/50" if state == :upcoming %>"><%= t("onboarding.steps.#{step}") %></span>
      <% unless i == steps.size - 1 %>
        <span class="mx-3 h-px flex-1 <%= i < current_index ? "bg-primary" : "bg-base-300" %>"></span>
      <% end %>
    </li>
  <% end %>
</ol>
