<%# "Skip to the app" — accounts/incomes/cards, for every user (new owner or invited member).
    profile never renders it (name + phone required-first); creating transactions/commitments
    stays blocked until the account has an instrument. %>
<div class="mt-4 text-center">
  <%= button_to t("onboarding.skip_to_app"), onboarding_skip_path, method: :patch,
        class: "btn btn-ghost btn-sm text-base-content/60" %>
  <p class="mt-1 text-xs text-base-content/50"><%= t("onboarding.skip_hint") %></p>
</div>
