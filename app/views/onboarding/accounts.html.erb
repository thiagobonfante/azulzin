<% content_for :title, t("onboarding.accounts.meta_title") %>

<div>
  <h1 class="font-display text-2xl font-extrabold tracking-tight sm:text-3xl"><%= t("onboarding.accounts.title") %></h1>
  <p class="mt-2 text-base-content/70"><%= t("onboarding.accounts.subtitle") %></p>

  <div class="mt-6">
    <%= render "document_imports/uploader" %>
  </div>

  <div id="bank_accounts_list" class="mt-6 flex flex-col gap-3">
    <% if @bank_accounts.any? %>
      <%= render @bank_accounts %>
    <% else %>
      <%= render "bank_accounts/empty" %>
    <% end %>
  </div>

  <div class="mt-6 rounded-box border border-base-300/70 bg-base-100 p-5 shadow-sm">
    <h2 class="mb-4 font-display text-lg font-bold"><%= t("bank_accounts.add_title") %></h2>
    <%= render "bank_accounts/form", bank_account: @bank_account %>
  </div>

  <div class="mt-8 flex items-center justify-between">
    <%= link_to t("onboarding.back"), onboarding_step_path("profile"), class: "btn btn-ghost" %>
    <%= form_with url: onboarding_step_path("accounts"), method: :patch do |f| %>
      <%= f.submit t("onboarding.accounts.continue"), class: "btn btn-primary" %>
    <% end %>
  </div>
  <p class="mt-3 text-right text-xs text-base-content/50"><%= t("onboarding.accounts.need_one_hint") %></p>
  <%= render "skip" %>
</div>
