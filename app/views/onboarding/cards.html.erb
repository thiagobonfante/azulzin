<% content_for :title, t("onboarding.cards.meta_title") %>

<div>
  <h1 class="font-display text-2xl font-extrabold tracking-tight sm:text-3xl"><%= t("onboarding.cards.title") %></h1>
  <p class="mt-2 text-base-content/70"><%= t("onboarding.cards.subtitle") %></p>

  <div id="credit_cards_list" class="mt-6 flex flex-col gap-3">
    <% if @credit_cards.any? %>
      <%= render @credit_cards %>
    <% else %>
      <%= render "credit_cards/empty" %>
    <% end %>
  </div>

  <div class="mt-6 rounded-box border border-base-300/70 bg-base-100 p-5 shadow-sm">
    <h2 class="mb-4 font-display text-lg font-bold"><%= t("credit_cards.add_title") %></h2>
    <%= render "credit_cards/form", credit_card: @credit_card %>
  </div>

  <div class="mt-8 flex items-center justify-between">
    <%= link_to t("onboarding.back"), onboarding_step_path("accounts"), class: "btn btn-ghost" %>
    <%= form_with url: onboarding_step_path("cards"), method: :patch do |f| %>
      <%= f.submit t("onboarding.cards.finish"), class: "btn btn-primary" %>
    <% end %>
  </div>
  <p class="mt-3 text-right text-xs text-base-content/50"><%= t("onboarding.cards.optional_hint") %></p>
</div>
