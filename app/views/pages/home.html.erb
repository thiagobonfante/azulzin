<% content_for :title, "azulzin — calm personal finance" %>

<section class="relative overflow-hidden">
  <%# soft blue wash — decorative only %>
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute -left-24 -top-24 h-96 w-96 rounded-full bg-primary/20 blur-3xl"></div>
    <div class="absolute right-0 top-32 h-80 w-80 rounded-full bg-secondary/25 blur-3xl"></div>
  </div>

  <div class="container mx-auto grid items-center gap-12 px-5 py-16 lg:grid-cols-2 lg:py-24">
    <%# ── Hero thesis ─────────────────────────────────────────────── %>
    <div class="max-w-xl">
      <span class="badge badge-outline badge-lg gap-2 border-primary/30 text-primary">
        <span class="h-2 w-2 rounded-full bg-primary"></span>
        Personal finance, made calm
      </span>

      <h1 class="mt-6 font-display text-4xl font-extrabold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl">
        Your money,<br>
        <span class="text-primary">finally calm.</span>
      </h1>

      <p class="mt-6 text-lg leading-relaxed text-base-content/70">
        azulzin brings everything you earn and spend into one simple, gentle view —
        so you always know where you stand, without the spreadsheets.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href="#" class="btn btn-primary btn-lg">Get started — it's free</a>
        <a href="#features" class="btn btn-ghost btn-lg">See how it works</a>
      </div>

      <p class="mt-6 text-sm text-base-content/55">No jargon. No judgement. Just clarity.</p>
    </div>

    <%# ── Signature: the balance card ─────────────────────────────── %>
    <div class="relative mx-auto w-full max-w-md lg:mx-0 lg:ml-auto">
      <div class="card border border-base-300/70 bg-base-100 shadow-xl">
        <div class="card-body gap-6">
          <div class="flex items-start justify-between">
            <div>
              <p class="text-sm font-medium text-base-content/60">Total balance</p>
              <p class="mt-1 font-display text-4xl font-extrabold tabular-nums tracking-tight">
                R$&nbsp;12.480<span class="text-base-content/50">,00</span>
              </p>
            </div>
            <span class="badge badge-success gap-1 font-medium">▲ 2,4%</span>
          </div>

          <%# a calm week of cash flow — decorative sample %>
          <div>
            <div class="flex h-24 items-end justify-between gap-2" aria-hidden="true">
              <div class="w-full rounded-t-md bg-primary/25" style="height:42%"></div>
              <div class="w-full rounded-t-md bg-primary/35" style="height:60%"></div>
              <div class="w-full rounded-t-md bg-primary/30" style="height:48%"></div>
              <div class="w-full rounded-t-md bg-primary/60" style="height:82%"></div>
              <div class="w-full rounded-t-md bg-primary/40" style="height:55%"></div>
              <div class="w-full rounded-t-md bg-primary" style="height:95%"></div>
              <div class="w-full rounded-t-md bg-primary/45" style="height:64%"></div>
            </div>
            <div class="mt-2 flex justify-between text-xs text-base-content/40">
              <span>Mon</span><span>Sun</span>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div class="rounded-box bg-success/10 px-4 py-3">
              <p class="text-xs font-medium text-success">In this month</p>
              <p class="mt-0.5 font-display text-lg font-bold tabular-nums">R$&nbsp;6.200</p>
            </div>
            <div class="rounded-box bg-error/10 px-4 py-3">
              <p class="text-xs font-medium text-error">Out this month</p>
              <p class="mt-0.5 font-display text-lg font-bold tabular-nums">R$&nbsp;3.940</p>
            </div>
          </div>
        </div>
      </div>
      <span class="absolute -right-2 -top-2 badge badge-neutral badge-sm">Preview</span>
    </div>
  </div>
</section>

<%# ── Three simple promises ───────────────────────────────────────── %>
<section id="features" class="container mx-auto px-5 pb-20 lg:pb-28">
  <div class="grid gap-5 sm:grid-cols-3">
    <div class="card border border-base-300/70 bg-base-100 transition-shadow hover:shadow-md">
      <div class="card-body gap-3">
        <span class="inline-grid h-11 w-11 place-items-center rounded-xl bg-primary/10 text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9V6.75A2.25 2.25 0 014.5 4.5h15a2.25 2.25 0 012.25 2.25v10.5A2.25 2.25 0 0119.5 19.5h-15A2.25 2.25 0 012.25 17.25V9z"/>
          </svg>
        </span>
        <h3 class="card-title font-display text-lg">Track every cent</h3>
        <p class="text-base-content/65">Log income and expenses in seconds, and watch your balance stay up to date.</p>
      </div>
    </div>

    <div class="card border border-base-300/70 bg-base-100 transition-shadow hover:shadow-md">
      <div class="card-body gap-3">
        <span class="inline-grid h-11 w-11 place-items-center rounded-xl bg-primary/10 text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m0 13.5V21m9-9h-2.25M5.25 12H3m15.364-6.364l-1.591 1.591M7.227 16.773l-1.591 1.591M18.364 18.364l-1.591-1.591M7.227 7.227L5.636 5.636"/>
            <circle cx="12" cy="12" r="3.25"/>
          </svg>
        </span>
        <h3 class="card-title font-display text-lg">Budgets that breathe</h3>
        <p class="text-base-content/65">Set gentle limits per category and always see how much room you have left.</p>
      </div>
    </div>

    <div class="card border border-base-300/70 bg-base-100 transition-shadow hover:shadow-md">
      <div class="card-body gap-3">
        <span class="inline-grid h-11 w-11 place-items-center rounded-xl bg-primary/10 text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 3v16.5A1.5 1.5 0 004.5 21H21M7.5 15l3-3 3 2.25L18 9"/>
          </svg>
        </span>
        <h3 class="card-title font-display text-lg">See where it goes</h3>
        <p class="text-base-content/65">Clear, uncluttered summaries turn your spending into something you can actually read.</p>
      </div>
    </div>
  </div>
</section>
