<% content_for :title, t(".title") %>
<div class="container mx-auto flex justify-center px-5 py-16">
  <div class="card w-full max-w-md border border-base-300/70 bg-base-100 shadow-xl">
    <div class="card-body gap-6">
      <h1 class="font-display text-3xl font-extrabold tracking-tight"><%= t(".title") %></h1>

      <%= form_with url: password_path(params[:token]), method: :put, class: "flex flex-col gap-4" do |form| %>
        <div class="form-control">
          <label for="password" class="mb-1 block text-sm font-medium"><%= User.human_attribute_name(:password) %></label>
          <%= form.password_field :password, required: true, autofocus: true, autocomplete: "new-password", placeholder: t(".password_placeholder"), maxlength: 72, class: "input input-bordered w-full" %>
        </div>

        <div class="form-control">
          <label for="password_confirmation" class="mb-1 block text-sm font-medium"><%= User.human_attribute_name(:password_confirmation) %></label>
          <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: t(".password_confirmation_placeholder"), maxlength: 72, class: "input input-bordered w-full" %>
        </div>

        <%= form.submit t(".submit"), class: "btn btn-primary w-full" %>
      <% end %>
    </div>
  </div>
</div>
