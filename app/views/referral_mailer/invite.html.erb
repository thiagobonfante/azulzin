<div style="max-width: 480px; margin: 0 auto; font-family: -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; color: #1f2937;">
  <p style="font-size: 26px; font-weight: 800; color: #2563eb; margin: 32px 0 20px;">azulzin</p>

  <div style="background: #eff6ff; border-radius: 16px; padding: 24px;">
    <p style="font-size: 18px; font-weight: 600; margin: 0 0 8px;"><%= t(".headline", inviter: @inviter.display_name) %></p>
    <p style="margin: 0; line-height: 1.6;"><%= t(".intro") %></p>
  </div>

  <ul style="padding-left: 20px; margin: 24px 0; line-height: 1.9;">
    <li><%= t(".point_whatsapp") %></li>
    <li><%= t(".point_family") %></li>
    <li><%= t(".point_goals") %></li>
  </ul>

  <p style="margin: 28px 0; text-align: center;">
    <a href="<%= @url %>" style="display: inline-block; padding: 14px 28px; background: #2563eb; color: #ffffff; border-radius: 9999px; text-decoration: none; font-weight: 600;">
      <%= t(".cta") %>
    </a>
  </p>

  <p style="color: #6b7280; font-size: 13px; text-align: center;"><%= t(".ignore") %></p>
</div>
