<div class="container mx-auto flex justify-center px-5 py-16">
  <div class="card w-full max-w-md border border-base-300/70 bg-base-100 shadow-xl">
    <div class="card-body gap-6">
      <h1 class="font-display text-3xl font-extrabold tracking-tight"><%= t(".title") %></h1>

      <%= form_with model: @user, url: registration_path, class: "flex flex-col gap-4" do |form| %>
        <% if @user.errors.any? %>
          <div class="alert alert-error" role="alert">
            <ul class="list-disc pl-4">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="form-control">
          <%= form.label :email_address, class: "mb-1 block text-sm font-medium" %>
          <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", class: "input input-bordered w-full" %>
        </div>

        <div class="form-control">
          <%= form.label :password, class: "mb-1 block text-sm font-medium" %>
          <%= form.password_field :password, required: true, autocomplete: "new-password", maxlength: 72, class: "input input-bordered w-full" %>
        </div>

        <div class="form-control">
          <%= form.label :password_confirmation, class: "mb-1 block text-sm font-medium" %>
          <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72, class: "input input-bordered w-full" %>
        </div>

        <%= form.submit t(".submit"), class: "btn btn-primary w-full" %>
      <% end %>

      <div class="divider my-0 text-sm opacity-60"><%= t("shared.or") %></div>

      <%= button_to t("shared.continue_with_google"), "/auth/google_oauth2",
            data: { turbo: false }, class: "btn btn-outline w-full" %>

      <p class="text-center text-sm opacity-70">
        <%= t(".sign_in_prompt") %>
        <%= link_to t(".sign_in_link"), new_session_path, class: "link link-hover font-medium" %>
      </p>
    </div>
  </div>
</div>
