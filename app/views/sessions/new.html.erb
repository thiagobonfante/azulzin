<% content_for :title, t(".title") %>
<div class="container mx-auto flex justify-center px-5 py-16">
  <div class="card w-full max-w-md border border-base-300/70 bg-base-100 shadow-xl">
    <div class="card-body gap-6">
      <h1 class="font-display text-3xl font-extrabold tracking-tight"><%= t(".title") %></h1>

      <%= form_with url: session_url, class: "flex flex-col gap-4" do |form| %>
        <div class="form-control">
          <label for="email_address" class="mb-1 block text-sm font-medium"><%= User.human_attribute_name(:email_address) %></label>
          <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: t(".email_placeholder"), value: params[:email_address], class: "input input-bordered w-full" %>
        </div>

        <div class="form-control">
          <label for="password" class="mb-1 block text-sm font-medium"><%= User.human_attribute_name(:password) %></label>
          <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: t(".password_placeholder"), maxlength: 72, class: "input input-bordered w-full" %>
        </div>

        <%= form.submit t(".submit"), class: "btn btn-primary w-full" %>

        <div class="text-center text-sm">
          <%= link_to t(".forgot_password"), new_password_path, class: "link link-hover opacity-70" %>
        </div>
      <% end %>

      <%# Hidden in the native shells: Google returns 403 disallowed_useragent inside
          webviews. Google-only accounts set a password via "esqueci a senha". %>
      <% unless turbo_native_app? %>
        <div class="divider my-0 text-sm opacity-60"><%= t("shared.or") %></div>

        <%= button_to t("shared.continue_with_google"), "/auth/google_oauth2",
              data: { turbo: false }, class: "btn btn-outline w-full" %>
      <% end %>

      <details class="text-sm">
        <summary class="cursor-pointer opacity-70"><%= t(".resend_summary") %></summary>
        <%= form_with url: resend_email_verification_path, class: "mt-3 flex gap-2" do |form| %>
          <%= form.email_field :email_address, required: true, autocomplete: "username", placeholder: t(".resend_placeholder"), class: "input input-bordered input-sm flex-1" %>
          <%= form.submit t(".resend_submit"), class: "btn btn-sm" %>
        <% end %>
      </details>
    </div>
  </div>
</div>
