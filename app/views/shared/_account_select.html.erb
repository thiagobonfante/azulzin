<%# locals: form, accounts, label, placeholder %>
<%# Searchable account picker with brand avatars — mirrors shared/institution_select and
    reuses its generic controller (hidden input + button + option list). %>
<div class="form-control" data-controller="institution-select">
  <%= form.label :bank_account_id, label, class: "mb-1 block text-sm font-medium" %>

  <%# Real value, set by the picker. No <noscript> fallback — see shared/_institution_select. %>
  <%= form.hidden_field :bank_account_id, data: { institution_select_target: "input" } %>

  <button type="button"
          data-institution-select-target="button"
          data-action="institution-select#toggle"
          class="input input-bordered flex w-full items-center justify-between gap-2 text-left">
    <span data-institution-select-target="display" class="flex items-center gap-2 text-base-content/50">
      <%= placeholder %>
    </span>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
  </button>

  <div data-institution-select-target="panel" hidden class="relative">
    <div class="absolute z-40 mt-1 w-full rounded-box border border-base-300/70 bg-base-100 p-2 shadow-lg">
      <input type="text"
             data-institution-select-target="search"
             data-action="input->institution-select#filter keydown->institution-select#onKeydown"
             placeholder="<%= t('institutions.search') %>"
             class="input input-bordered input-sm mb-2 w-full"
             autocomplete="off">
      <ul class="max-h-64 overflow-y-auto">
        <% accounts.each do |account| %>
          <li data-institution-select-target="option"
              data-value="<%= account.id %>"
              data-name="<%= account.display_name.downcase %>"
              data-action="click->institution-select#pick"
              class="flex cursor-pointer items-center gap-3 rounded-box px-2 py-2 hover:bg-base-200">
            <span data-label class="flex items-center gap-2">
              <%= institution_avatar(account.institution, size: 28) %>
              <span class="text-sm font-medium"><%= account.display_name %></span>
            </span>
          </li>
        <% end %>
      </ul>
    </div>
  </div>

</div>
