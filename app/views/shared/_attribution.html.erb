<%# locals: record, full: (defaults false). Renders NOTHING on solo accounts — the guard lives
    here so call sites stay unconditional (doc 06 §5 / spine D7). %>
<% if Current.account.members_count > 1 %>
  <% creator = record.created_by&.display_name || t("shared.attribution.removed_user") %>
  <% editor  = record.updated_by&.display_name %>
  <% if local_assigns[:full] %>
    <span class="text-xs text-base-content/50">
      <%= t("shared.attribution.by", name: creator) %><% if editor && editor != creator
        %> · <%= t("shared.attribution.edited_by", name: editor) %><% end %>
    </span>
  <% else %>
    <span class="tooltip align-middle" data-tip="<%= t("shared.attribution.by", name: creator) %><%=
      " · #{t('shared.attribution.edited_by', name: editor)}" if editor && editor != creator %>">
      <span class="inline-grid h-5 w-5 place-items-center rounded-full bg-primary/15
                   text-[10px] font-semibold text-primary"><%= creator.first.upcase %></span>
    </span>
  <% end %>
<% end %>
