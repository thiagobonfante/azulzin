<%# locals: institutions, plus EITHER form: (model forms — value is the institution id) OR
    name:/selected: (bare field, e.g. the import review's edits[pid][institution_code] — value
    is the COMPE code via value_method). label: false renders compact (aria-label only). %>
<% value_method = local_assigns.fetch(:value_method, :id) %>
<% show_label   = local_assigns.fetch(:label, true) %>
<div class="form-control" data-controller="institution-select">
  <% if local_assigns[:form] %>
    <% if show_label %>
      <%= form.label :institution_id, t("institutions.label"), class: "mb-1 block text-sm font-medium" %>
    <% end %>
    <%# Real value, set by the picker. NO <noscript> fallback here: Turbo parses frame/stream
        responses with DOMParser (scripting off), which turns noscript content into a LIVE
        duplicate field that overrides the picked value — the last param wins server-side. %>
    <%= form.hidden_field :institution_id, data: { institution_select_target: "input" } %>
  <% else %>
    <%= hidden_field_tag name, selected, data: { institution_select_target: "input" } %>
  <% end %>

  <button type="button"
          data-institution-select-target="button"
          data-action="institution-select#toggle"
          <% unless show_label %>aria-label="<%= t("institutions.label") %>"<% end %>
          class="input input-bordered flex w-full items-center justify-between gap-2 text-left">
    <span data-institution-select-target="display" class="flex items-center gap-2 text-base-content/50">
      <%= t("institutions.placeholder") %>
    </span>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
  </button>

  <div data-institution-select-target="panel" hidden class="relative">
    <div class="absolute z-40 mt-1 w-full rounded-box border border-base-300/70 bg-base-100 p-2 shadow-lg">
      <input type="text"
             data-institution-select-target="search"
             data-action="input->institution-select#filter keydown->institution-select#onKeydown"
             placeholder="<%= t('institutions.search') %>"
             class="input input-bordered input-sm mb-2 w-full"
             autocomplete="off">
      <ul class="max-h-64 overflow-y-auto">
        <% institutions.each do |inst| %>
          <li data-institution-select-target="option"
              data-value="<%= inst.public_send(value_method) %>"
              data-name="<%= inst.display_name.downcase %>"
              data-action="click->institution-select#pick"
              class="flex cursor-pointer items-center gap-3 rounded-box px-2 py-2 hover:bg-base-200">
            <span data-label class="flex items-center gap-2">
              <%= institution_avatar(inst, size: 28) %>
              <span class="text-sm font-medium"><%= inst.display_name %></span>
            </span>
          </li>
        <% end %>
      </ul>
    </div>
  </div>

</div>
