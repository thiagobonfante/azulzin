<%# Refer-a-friend dialog — opened by a sibling [data-action="modal#open"] button inside
    a data-controller="modal" wrapper (sidebar bottom on web, Mais menu row on native).
    WhatsApp path is a share link (wa.me/?text=…): opens the user's own WhatsApp
    with the message prefilled, they pick the contacts — we never send anything. %>
<dialog data-modal-target="dialog" class="modal modal-bottom sm:modal-middle">
  <%# Full-width bottom sheet on mobile (a max-w there corner-pins the box: modal-bottom
      is place-items:end); cap the width only from sm: up. %>
  <div class="modal-box sm:max-w-md text-left">
    <form method="dialog">
      <button class="btn btn-ghost btn-sm btn-circle absolute right-2 top-2"
              aria-label="<%= t("shared.cancel") %>">✕</button>
    </form>
    <h3 class="font-display text-lg font-bold"><%= t("referrals.modal.title") %></h3>
    <p class="mt-1 text-sm text-base-content/60"><%= t("referrals.modal.subtitle") %></p>

    <a href="https://wa.me/?text=<%= u t("referrals.modal.whatsapp_message") %>"
       target="_blank" rel="noopener"
       class="btn mt-4 w-full border-none bg-[#25D366] text-white hover:bg-[#1ebe5b]">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      <%= t("referrals.modal.whatsapp_cta") %>
    </a>

    <div class="divider text-xs text-base-content/40"><%= t("referrals.modal.or") %></div>

    <%= form_with scope: :referral, url: referral_path, class: "flex gap-2" do |f| %>
      <%# multiple: true lets the browser validate a comma-separated list, but it also
          rewrites the name to referral[email][] — pin the scalar name the controller expects. %>
      <%= f.email_field :email, required: true, multiple: true, name: "referral[email]",
            placeholder: t("referrals.modal.email_placeholder"),
            class: "input input-bordered input-sm min-w-0 flex-1" %>
      <%= f.submit t("referrals.modal.send"), class: "btn btn-primary btn-sm" %>
    <% end %>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button aria-label="<%= t("shared.cancel") %>">close</button>
  </form>
</dialog>
