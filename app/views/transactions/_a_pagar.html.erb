<%# locals: occurrences, month — Zone E. Hidden entirely when the month has no occurrences.
    Only unpaid debit occurrences need action here; card items settle through the fatura and
    paid items are history — both collapse into one-line groups so a heavy month stays scannable. %>
<% open_rows = occurrences.reject { |o| o.paid? || o.card? }.sort_by(&:due_on) %>
<% card_rows = occurrences.select(&:card?).sort_by { |o| [ o.paid? ? 1 : 0, o.due_on ] } %>
<% paid_rows = occurrences.select { |o| o.paid? && !o.card? }.sort_by(&:due_on) %>
<% if occurrences.any? %>
  <section id="a_pagar" class="rounded-box border border-base-300/70 bg-base-100 p-4 shadow-sm">
    <header class="mb-2 flex items-center justify-between">
      <h2 class="text-sm font-semibold">
        <%= t("transactions.due.title") %>
        <%= link_to "(#{t("app.nav.commitments")})", commitments_path, class: "text-xs font-normal text-primary hover:underline" %>
      </h2>
      <span class="font-display text-sm font-bold tabular-nums">
        <%= brl(occurrences.reject(&:paid?).sum { |o| o.commitment.amount_cents }) %>
      </span>
    </header>

    <% if open_rows.any? %>
      <div class="divide-y divide-base-300/40">
        <% open_rows.each do |occurrence| %>
          <%= render "commitments/occurrence", occurrence: occurrence, context: :hub %>
        <% end %>
      </div>
    <% elsif paid_rows.any? %>
      <p class="py-2 text-sm text-base-content/50"><%= t("transactions.due.all_paid") %></p>
    <% end %>

    <% if card_rows.any? %>
      <details class="group border-t border-base-300/40">
        <summary class="flex cursor-pointer list-none items-center justify-between py-2 text-sm text-base-content/60 hover:text-base-content">
          <span class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-base-content/40 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
            <%= t("transactions.due.on_card", count: card_rows.size) %>
          </span>
          <span class="tabular-nums"><%= brl(card_rows.sum { |o| o.payment&.amount_cents || o.commitment.amount_cents }) %></span>
        </summary>
        <div class="divide-y divide-base-300/40 pl-5">
          <% card_rows.each do |occurrence| %>
            <%= render "commitments/occurrence", occurrence: occurrence, context: :hub %>
          <% end %>
        </div>
      </details>
    <% end %>

    <% if paid_rows.any? %>
      <details class="group border-t border-base-300/40">
        <summary class="flex cursor-pointer list-none items-center justify-between py-2 text-sm text-base-content/60 hover:text-base-content">
          <span class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-base-content/40 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
            <%= t("transactions.due.paid_group", count: paid_rows.size) %>
          </span>
          <span class="tabular-nums"><%= brl(paid_rows.sum { |o| o.payment&.amount_cents || o.commitment.amount_cents }) %></span>
        </summary>
        <div class="divide-y divide-base-300/40 pl-5">
          <% paid_rows.each do |occurrence| %>
            <%= render "commitments/occurrence", occurrence: occurrence, context: :hub %>
          <% end %>
        </div>
      </details>
    <% end %>
  </section>
<% end %>
