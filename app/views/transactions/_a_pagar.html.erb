<%# locals: occurrences, month — Zone E. Hidden entirely when the month has no occurrences. %>
<% rows = occurrences.sort_by { |o| [ o.paid? ? 1 : 0, o.due_on ] } %>
<% if rows.any? %>
  <section id="a_pagar" class="rounded-box border border-base-300/70 bg-base-100 p-4 shadow-sm">
    <header class="mb-2 flex items-center justify-between">
      <h2 class="text-sm font-semibold">
        <%= t("transactions.due.title") %>
        <%= link_to "(#{t("app.nav.commitments")})", commitments_path, class: "text-xs font-normal text-primary hover:underline" %>
      </h2>
      <span class="font-display text-sm font-bold tabular-nums">
        <%= brl(occurrences.reject(&:paid?).sum { |o| o.commitment.amount_cents }) %>
      </span>
    </header>
    <div class="divide-y divide-base-300/40">
      <% rows.each do |occurrence| %>
        <%= render "commitments/occurrence", occurrence: occurrence, context: :hub %>
      <% end %>
    </div>
  </section>
<% end %>
