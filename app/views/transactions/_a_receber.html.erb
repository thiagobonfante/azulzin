<%# locals: summary, month — Zone E, A receber no mês (R1). The income twin of "A pagar":
    each recurring income with its expected date; "Recebi" posts the deposit (income_id link)
    so it joins the account balance. Projection months only — past months show nothing. %>
<div id="a_receber">
  <% incomes = Current.user.incomes.active.includes(bank_account: :institution).order(:created_at) %>
  <% if summary.mode != :past && incomes.any? %>
    <% pending = incomes.reject { |i| summary.income_received?(i) } %>
    <section class="rounded-box border border-base-300/70 bg-base-100 p-4 shadow-sm">
      <header class="mb-2 flex items-center justify-between">
        <h2 class="text-sm font-semibold">
          <%= t("transactions.receivable.title") %>
          <%= link_to "(#{t("app.nav.incomes")})", incomes_path, class: "text-xs font-normal text-primary hover:underline" %>
        </h2>
        <span class="font-display text-sm font-bold tabular-nums text-success">
          <%= brl(pending.sum(&:amount_cents)) %>
        </span>
      </header>
      <div class="divide-y divide-base-300/40">
        <% incomes.sort_by { |i| [ summary.income_received?(i) ? 1 : 0, i.expected_on(month) ] }.each do |income| %>
          <% received = summary.income_received?(income) %>
          <div class="flex items-center gap-2 py-2">
            <div class="min-w-0 flex-1">
              <p class="truncate text-sm"><%= income.name %></p>
              <p class="text-xs text-base-content/50">
                <%= l(income.expected_on(month), format: :short) %> · <%= income.bank_account.display_name %>
              </p>
            </div>
            <span class="badge <%= received ? "badge-success" : "badge-ghost" %> badge-xs">
              <%= received ? t("transactions.receivable.received") : t("transactions.receivable.expected") %>
            </span>
            <span class="tabular-nums text-sm text-success">+<%= brl(income.amount_cents) %></span>
            <% if !received && month <= hub_today.beginning_of_month %>
              <%= button_to t("transactions.receivable.mark_received"),
                    receive_income_path(income, month: month.strftime("%Y-%m")),
                    method: :patch, class: "btn btn-primary btn-xs" %>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
