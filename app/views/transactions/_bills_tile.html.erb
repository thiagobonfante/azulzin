<%# locals: summary, month — Zone D, Faturas do mês. "What will the cards take this month?" %>
<section id="bills_tile" class="rounded-box border border-base-300/70 bg-base-100 p-4 shadow-sm">
  <header class="mb-3 flex items-baseline justify-between">
    <h2 class="text-sm font-semibold">
      <%= link_to credit_cards_path, class: "inline-flex items-center gap-1 hover:text-primary" do %>
        <%= t("transactions.bills.title") %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-base-content/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
      <% end %>
    </h2>
    <span class="font-display text-lg font-bold tabular-nums"><%= brl(summary.faturas_cents) %></span>
  </header>

  <% cards = Current.account.credit_cards.kept.includes(:institution).order(:created_at) %>
  <% if cards.any? %>
    <ul class="flex flex-col gap-3">
      <% cards.each do |card| %>
        <li>
          <% lines = card.billing_configured? ? card.transactions.posted.where(billing_month: month).order(:occurred_on).to_a : [] %>
          <%# The card block itself toggles its fatura lines (no separate "Ver fatura" link);
              the chevron by the name signals it. Shared header so both branches stay identical. %>
          <% header = capture do %>
            <div class="flex items-center gap-2">
              <%= institution_avatar(card.institution, size: 28) %>
              <span class="flex min-w-0 flex-1 items-center gap-1 truncate text-sm">
                <span class="truncate"><%= card.display_name %></span>
                <% if lines.any? %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 shrink-0 text-base-content/40 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
                <% end %>
              </span>
              <span class="tabular-nums text-sm font-medium"><%= brl(summary.bill_totals[card].to_i) %></span>
            </div>
            <% if card.billing_configured? %>
              <p class="mt-0.5 pl-9 text-xs text-base-content/50">
                <%= t("transactions.bills.due_on", day: card.bill_due_day) %> ·
                <%= t("transactions.bills.closes_on", day: card.closing_date(card.current_open_bill_month).day) %>
              </p>
              <% if card.limit_informed? %>
                <% ratio = card.usage_ratio %>
                <% bar = ratio >= 0.9 ? "bg-error" : ratio >= 0.7 ? "bg-warning" : "bg-primary" %>
                <div class="mt-1 ml-9 h-2 overflow-hidden rounded-full bg-base-200">
                  <div class="h-full rounded-full <%= bar %>" style="width: <%= (ratio * 100).round %>%"></div>
                </div>
              <% end %>
            <% end %>
          <% end %>

          <% if lines.any? %>
            <details class="group">
              <summary class="cursor-pointer list-none"><%= header %></summary>
              <div class="mt-2 ml-9">
                <%= render "card_bills/lines", lines: lines %>
              </div>
            </details>
          <% else %>
            <%= header %>
            <% unless card.billing_configured? %>
              <%= link_to t("transactions.bills.setup_billing"),
                    edit_credit_card_path(card, return_to: "transactions", month: month.strftime("%Y-%m")),
                    class: "mt-1 ml-9 inline-block text-xs font-medium text-primary hover:underline" %>
            <% end %>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <%= link_to t("dashboard.add_cards"), credit_cards_path,
          class: "block rounded-box border border-dashed border-base-300 px-4 py-6 text-center text-sm text-primary" %>
  <% end %>

</section>
