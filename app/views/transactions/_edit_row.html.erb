<%# locals: transaction — edit-in-place. The display line stays on top (the row never
    "disappears"); the form expands under it inside a highlighted border. %>
<%= turbo_frame_tag dom_id(transaction, :row), class: "block" do %>
  <div class="my-1 rounded-box border border-primary/40 bg-base-100 ring-1 ring-primary/20">
    <div class="flex items-center gap-3 border-b border-base-300/40 px-2 py-2.5">
      <%= render "transactions/row_display", transaction: transaction %>
    </div>
    <%= render "shared/attribution", record: transaction, full: true %>
    <%= form_with model: transaction, url: transaction_path(transaction), method: :patch,
          class: "grid gap-2 p-2 sm:grid-cols-2" do |f| %>
      <%= hidden_field_tag :from, "ledger" %>
      <%= hidden_field_tag :month, params[:month] %>
      <% if transaction.errors.any? %>
        <div class="alert alert-error col-span-full py-1 text-xs" role="alert"><span><%= transaction.errors.full_messages.to_sentence %></span></div>
      <% end %>

      <div class="form-control">
        <%= f.label :amount_reais, t("transactions.row.amount"), class: "mb-1 text-xs text-base-content/60" %>
        <label class="input input-bordered input-sm flex items-center gap-1">
          <span class="text-base-content/50"><%= t("money.symbol") %></span>
          <%= f.text_field :amount_reais, inputmode: "decimal", class: "grow" %>
        </label>
      </div>
      <div class="form-control">
        <%= f.label :merchant, t("transactions.row.merchant"), class: "mb-1 text-xs text-base-content/60" %>
        <%= f.text_field :merchant, class: "input input-bordered input-sm w-full" %>
      </div>
      <div class="form-control">
        <%= f.label :occurred_on, t("transactions.row.date"), class: "mb-1 text-xs text-base-content/60" %>
        <%= f.date_field :occurred_on, class: "input input-bordered input-sm w-full" %>
      </div>

      <% if transaction.transfer? %>
        <div class="form-control">
          <%= f.label :transfer_to_bank_account_id, t("transfers.form.to"), class: "mb-1 text-xs text-base-content/60" %>
          <%= f.collection_select :transfer_to_bank_account_id, Current.account.bank_accounts.kept.includes(:institution).order(:created_at),
                :id, :display_name, {}, class: "select select-bordered select-sm w-full" %>
        </div>
      <% elsif transaction.credit_card_id %>
        <div class="form-control">
          <%= f.label :billing_month, t("transactions.row.bill_month"), class: "mb-1 text-xs text-base-content/60" %>
          <%= f.select :billing_month, fatura_month_options(transaction),
                { selected: transaction.billing_month.strftime("%Y-%m-%d") }, class: "select select-bordered select-sm w-full" %>
        </div>
      <% end %>

      <% unless transaction.transfer? %>
        <div class="form-control">
          <label class="mb-1 text-xs text-base-content/60"><%= t("transactions.row.category") %></label>
          <%= render "categories/picker", field_name: "transaction[category_id]", selected_id: transaction.category_id %>
        </div>
      <% end %>

      <%# Comprovante (up-tier F5): current attachment (image thumb → lightbox, PDF → link),
          plus the upload/replace field. Bytes are served only through the authenticated,
          account-scoped receipt action — never a bare blob URL. %>
      <div class="form-control col-span-full" data-controller="lightbox">
        <label class="mb-1 text-xs text-base-content/60"><%= t("transactions.row.receipt") %></label>
        <% if transaction.receipt.attached? %>
          <div class="mb-2 flex items-center gap-3">
            <% if transaction.receipt.image? %>
              <button type="button" data-action="lightbox#open" class="cursor-zoom-in" title="<%= t("transactions.row.view_receipt") %>">
                <%= image_tag receipt_transaction_path(transaction, size: "thumb"),
                      alt: t("transactions.row.view_receipt"),
                      class: "h-16 w-16 rounded-box object-cover ring-1 ring-base-300/70" %>
              </button>
              <dialog data-lightbox-target="dialog" class="modal">
                <div class="modal-box max-w-3xl bg-base-100 p-2">
                  <img data-src="<%= receipt_transaction_path(transaction) %>" alt="<%= t("transactions.row.view_receipt") %>"
                       class="mx-auto max-h-[80vh] rounded-box" />
                </div>
                <button type="button" class="modal-backdrop" data-action="lightbox#close"
                        aria-label="<%= t("transactions.row.close_receipt") %>"></button>
              </dialog>
            <% else %>
              <span class="grid h-10 w-10 shrink-0 place-items-center rounded-box bg-base-200 text-base-content/50">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-5 w-5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
              </span>
              <%= link_to t("transactions.row.view_receipt"), receipt_transaction_path(transaction),
                    target: "_blank", rel: "noopener", data: { turbo: false }, class: "link link-primary text-sm" %>
            <% end %>
          </div>
        <% end %>
        <%= f.file_field :receipt, accept: Transaction::RECEIPT_CONTENT_TYPES.join(","),
              aria: { label: t("transactions.row.attach_receipt") },
              class: "file-input file-input-bordered file-input-sm w-full" %>
      </div>

      <%# Direction fix-up (R7) — rare, kept behind a disclosure. %>
      <details class="form-control col-span-full">
        <summary class="cursor-pointer list-none text-xs text-base-content/50"><%= t("transactions.row.direction") %></summary>
        <%= f.select :direction, Transaction.directions.keys.map { |d| [ t("transactions.new_entry.#{d}"), d ] },
              { selected: transaction.direction }, class: "select select-bordered select-sm mt-1 w-full" %>
      </details>

      <div class="col-span-full flex items-center justify-end gap-2 pt-1">
        <%= link_to t("transactions.row.cancel"), transactions_path(month: params[:month]),
              data: { turbo_frame: dom_id(transaction, :row) }, class: "btn btn-ghost btn-sm" %>
        <%# A link (not button_to) so it isn't a <form> nested inside the edit form_with — nested
            forms are dropped by the browser, which is why delete + its confirm never fired. %>
        <%= link_to t("transactions.row.reverse"), transaction_path(transaction, month: params[:month], from: "ledger"),
              data: { turbo_method: :delete, turbo_confirm: t("transactions.row.confirm_discard") },
              class: "btn btn-ghost btn-sm text-error" %>
        <%= f.submit t("transactions.row.save"), class: "btn btn-primary btn-sm" %>
      </div>
    <% end %>
  </div>
<% end %>
