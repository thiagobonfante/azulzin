<%# Add/edit entry sheet — bottom sheet on mobile, centered on sm+ (same drawer as the
    commitment editor). The add + edit forms load into the shared entry_form frame; a
    successful save closes it, a 422 re-renders the form with errors inside. It lives outside
    movements_ledger so the ledger re-render on create/update never tears it down mid-submit.
    Shared by the hub (index) and the "Hoje" recent view. %>
<dialog data-entry-modal-target="dialog" data-action="close->entry-modal#onClose"
        class="modal modal-bottom sm:modal-middle">
  <div class="modal-box sm:max-w-lg text-left">
    <form method="dialog">
      <button class="btn btn-ghost btn-sm btn-circle absolute right-2 top-2"
              aria-label="<%= t("transactions.new_entry.close") %>">✕</button>
    </form>
    <%= turbo_frame_tag "entry_form", data: { entry_modal_target: "frame" } do %>
      <div class="flex justify-center py-10"><span class="loading loading-spinner loading-md text-primary"></span></div>
    <% end %>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button aria-label="<%= t("transactions.new_entry.close") %>">close</button>
  </form>
</dialog>
