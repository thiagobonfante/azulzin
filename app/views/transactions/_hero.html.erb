<%# locals: summary, month — Zone C. The product's one number. Blue ≥ 0, red < 0 (never green). %>
<%# Guardar dinheiro (R4) — the brand moment: with a surplus and somewhere to put it, hovering
    the sobra grows the number and teases a rotating phrase; clicking opens the save-money modal. %>
<% save_cta = summary.mode == :current && summary.remaining_cents.positive? &&
              Current.account.bank_accounts.kept.checking.exists? &&
              Current.account.bank_accounts.kept.where(kind: %w[savings investment]).exists? %>
<section id="hero" class="rounded-box border border-base-300/70 bg-base-100 p-5 shadow-sm"
         <% if save_cta %>data-controller="sobra-cta" data-sobra-cta-phrases-value="<%= t("transactions.hero.save_phrases").to_json %>"<% end %>>
  <% label = case summary.mode
             when :future then t("transactions.hero.remaining_projected")
             when :past   then t("transactions.hero.month_result")
             else              t("transactions.hero.remaining")
             end %>
  <div class="flex items-center gap-2">
    <span class="text-sm text-base-content/60"><%= label %></span>
    <% if summary.mode == :future %>
      <span class="badge badge-ghost badge-sm"><%= t("transactions.month.projection_badge") %></span>
    <% end %>
  </div>

  <div class="mt-1 flex flex-wrap items-baseline gap-3">
    <% amount_classes = "font-display text-4xl font-extrabold tabular-nums #{summary.in_the_blue? ? "text-primary" : "text-error"}" %>
    <% if save_cta %>
      <button type="button" aria-haspopup="dialog"
              class="<%= amount_classes %> origin-left cursor-pointer transition-transform duration-200 hover:scale-110 focus-visible:scale-110"
              data-action="sobra-cta#open mouseenter->sobra-cta#tease mouseleave->sobra-cta#untease focus->sobra-cta#tease blur->sobra-cta#untease">
        <%= brl(summary.remaining_cents) %>
      </button>
    <% else %>
      <span class="<%= amount_classes %>"><%= brl(summary.remaining_cents) %></span>
    <% end %>
    <span class="badge badge-ghost">
      <%= summary.in_the_blue? ? t("transactions.hero.in_the_blue") : t("transactions.hero.in_the_red") %>
    </span>
    <% if save_cta %>
      <span data-sobra-cta-target="phrase" aria-hidden="true"
            class="text-sm font-medium text-primary opacity-0 transition-opacity duration-200"></span>
    <% end %>
  </div>

  <%# Equation strip — the sobra math stays inspectable. %>
  <div class="mt-2 flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-base-content/50 tabular-nums">
    <a href="#ledger" class="hover:text-base-content"><%= t("transactions.hero.incomes") %> <span class="font-medium"><%= brl(summary.entradas_cents) %></span></a>
    <span aria-hidden="true">·</span>
    <a href="#ledger" class="hover:text-base-content"><%= t("transactions.hero.expenses") %> <span class="font-medium"><%= brl(summary.saidas_total_cents) %></span></a>
    <% if summary.guardado_cents.positive? %>
      <span aria-hidden="true">·</span>
      <a href="#accounts_tile" class="hover:text-base-content"><%= t("transactions.accounts.saved_total") %> <span class="font-medium"><%= brl(summary.guardado_cents) %></span></a>
    <% end %>
  </div>

  <% if (flow = monthly_flow_chart(Current.account, month)) %>
    <div class="mt-4"><%= flow %></div>
  <% end %>

  <% if save_cta %>
    <%= render "transactions/save_money_modal", summary: summary, month: month %>
  <% end %>
</section>
