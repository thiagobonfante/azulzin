<%# locals: ledger, month — Zone F. Everything editable in place (R7). %>
<section class="rounded-box border border-base-300/70 bg-base-100 p-4 shadow-sm">
  <header class="mb-3 flex items-center justify-between">
    <h2 id="ledger" class="text-sm font-semibold"><%= t("transactions.ledger.title") %></h2>
    <%= link_to new_transaction_path(kind: :expense, month: month.strftime("%Y-%m")),
          data: { turbo_frame: "new_entry" }, class: "btn btn-ghost btn-sm text-primary" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
      <%= t("transactions.ledger.add") %>
    <% end %>
  </header>

  <%= turbo_frame_tag "new_entry" %>

  <%= turbo_frame_tag "ledger" do %>
    <% current_filter = %w[expenses incomes transfers].include?(params[:filter]) ? params[:filter] : "all" %>
    <div class="mb-3 flex flex-wrap gap-1">
      <% %w[all expenses incomes transfers].each do |f| %>
        <%= link_to t("transactions.ledger.filters.#{f}"),
              transactions_path(month: month.strftime("%Y-%m"), filter: (f == "all" ? nil : f)),
              class: "btn btn-xs #{current_filter == f ? "btn-primary" : "btn-ghost"}" %>
      <% end %>
    </div>

    <% all_rows = ledger.to_a %>
    <%= render "transactions/category_bars", rows: all_rows %>

    <% rows = all_rows
       rows = rows.select { |r| r.direction == "expense" }  if current_filter == "expenses"
       rows = rows.select { |r| r.direction == "income" }   if current_filter == "incomes"
       rows = rows.select { |r| r.direction == "transfer" } if current_filter == "transfers" %>

    <% limit = params[:show_all].present? ? rows.size : 200 %>
    <div id="ledger_list" class="flex flex-col">
      <% if rows.any? %>
        <% rows.first(limit).group_by(&:occurred_on).each do |day, day_rows| %>
          <div class="sticky top-0 z-10 bg-base-200 px-2 py-1 text-xs text-base-content/50"><%= l(day, format: :weekday_day) %></div>
          <% day_rows.each do |txn| %>
            <%= render "transactions/ledger_row", transaction: txn %>
          <% end %>
        <% end %>
        <% if rows.size > limit %>
          <div class="mt-3 text-center">
            <%= link_to t("transactions.ledger.show_more"),
                  transactions_path(month: month.strftime("%Y-%m"), filter: (current_filter == "all" ? nil : current_filter), show_all: 1),
                  class: "btn btn-ghost btn-sm text-primary" %>
          </div>
        <% end %>
      <% else %>
        <%= render "transactions/ledger_empty", month: month %>
      <% end %>
    </div>
  <% end %>
</section>
