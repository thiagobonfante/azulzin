<%# locals: ledger, month — Zone F. Everything editable in place (R7). The inner frame content
    lives in _ledger_body so create can re-render the whole ledger (toolbar + list) at once. %>
<section class="rounded-box border border-base-300/70 bg-base-100 p-4 shadow-sm">
  <header class="mb-3 flex items-center justify-between">
    <h2 id="ledger" class="text-sm font-semibold"><%= t("transactions.ledger.title") %></h2>
    <div class="flex items-center gap-1">
      <%# up-tier F4 — the "get my data out" affordance; a full-page form, no new nav. %>
      <%= link_to new_export_path, class: "btn btn-ghost btn-sm text-base-content/60" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
        <%= t("transactions.ledger.export") %>
      <% end %>
      <%= link_to new_transaction_path(kind: :expense, month: month.strftime("%Y-%m")),
            data: { turbo_frame: "new_entry" }, class: "btn btn-ghost btn-sm text-primary" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
        <%= t("transactions.ledger.add") %>
      <% end %>
    </div>
  </header>

  <%= turbo_frame_tag "new_entry" %>

  <%# NB: distinct from the h2#ledger scroll anchor above — a shared id makes turbo_stream
      "replace" hit the wrong element and duplicate the list. %>
  <%= turbo_frame_tag "movements_ledger" do %>
    <%= render "transactions/ledger_body", ledger: ledger, month: month %>
  <% end %>
</section>
