<%# locals: ledger, month — the inner content of the "ledger" turbo frame. Extracted so create
    can re-render the whole thing (toolbar + list), which is what makes a first entry replace the
    empty state cleanly. Filtered server-side (kind tabs); searched / view-switched client-side. %>
<% current_filter = %w[expenses incomes transfers].include?(params[:filter]) ? params[:filter] : "all" %>
<%# Instrument filter — a whitelisted "bank_account-<id>" / "credit_card-<id>" token; anything
    else resolves to nil (= all). Applied before everything so totals and the by-category view
    reflect it too. A filtered bank account keeps its incoming transfers visible. %>
<% inst_type, inst_id = params[:instrument].to_s.split("-", 2) %>
<% current_instrument = case inst_type
                        when "bank_account" then Current.account.bank_accounts.kept.find_by(id: inst_id)
                        when "credit_card"  then Current.account.credit_cards.kept.find_by(id: inst_id)
                        end %>
<% instrument_token = current_instrument && params[:instrument] %>
<% all_rows = ledger.to_a %>
<% all_rows = case current_instrument
              when BankAccount
                all_rows.select { |r| r.bank_account_id == current_instrument.id || r.transfer_to_bank_account_id == current_instrument.id }
              when CreditCard
                all_rows.select { |r| r.credit_card_id == current_instrument.id }
              else all_rows
              end %>
<% has_expenses  = all_rows.any? { |r| r.direction == "expense" } %>
<% multi_account = Current.account.bank_accounts.kept.count >= 2 %>

<div data-controller="ledger">
  <% if all_rows.any? %>
    <%# Toolbar — search (list view) + List/Categories switch. The switch is pinned right with
        ml-auto so hiding the search in Categories view never makes it jump (issue 6a). %>
    <div class="mb-3 flex items-center gap-2">
      <label data-ledger-target="searchBox" class="input input-bordered input-sm flex flex-1 items-center gap-2 sm:max-w-xs">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 10.5a6.5 6.5 0 11-13 0 6.5 6.5 0 0113 0z" /></svg>
        <input type="search" data-ledger-target="search" data-action="input->ledger#filter"
               placeholder="<%= t('transactions.ledger.search_placeholder') %>"
               class="grow border-0 bg-transparent p-0 focus:outline-none" autocomplete="off">
      </label>

      <% if has_expenses %>
        <div class="join ml-auto shrink-0">
          <button type="button" data-ledger-target="viewBtn" data-view="list" data-action="ledger#showList"
                  class="btn btn-xs join-item btn-primary"><%= t("transactions.ledger.views.list") %></button>
          <button type="button" data-ledger-target="viewBtn" data-view="category" data-action="ledger#showCategory"
                  class="btn btn-xs join-item btn-ghost"><%= t("transactions.ledger.views.category") %></button>
        </div>
      <% end %>
    </div>

    <%# Kind filters (list view only) — the Transferências tab is hidden with a single account (R5). %>
    <div data-ledger-target="filters" class="mb-3 flex flex-wrap items-center gap-1">
      <% (multi_account ? %w[all expenses incomes transfers] : %w[all expenses incomes]).each do |f| %>
        <%= link_to t("transactions.ledger.filters.#{f}"),
              transactions_path(month: month.strftime("%Y-%m"), filter: (f == "all" ? nil : f), instrument: instrument_token),
              class: "btn btn-xs #{current_filter == f ? "btn-primary" : "btn-ghost"}" %>
      <% end %>

      <%# Instrument filter — only worth showing with more than one account/card to pick from. %>
      <% if inbox_bank_accounts.size + inbox_credit_cards.size >= 2 %>
        <%= form_with url: transactions_path, method: :get, class: "ml-auto" do %>
          <%= hidden_field_tag :month, month.strftime("%Y-%m") %>
          <% if current_filter != "all" %><%= hidden_field_tag :filter, current_filter %><% end %>
          <select name="instrument" data-action="change->ledger#submitFilter"
                  class="select select-bordered select-xs max-w-44"
                  aria-label="<%= t("transactions.ledger.instrument_all") %>">
            <option value=""><%= t("transactions.ledger.instrument_all") %></option>
            <% if inbox_bank_accounts.any? %>
              <optgroup label="<%= t("transactions.ledger.filter_accounts") %>">
                <% inbox_bank_accounts.each do |account| %>
                  <option value="bank_account-<%= account.id %>" <%= "selected" if instrument_token == "bank_account-#{account.id}" %>><%= account.display_name %></option>
                <% end %>
              </optgroup>
            <% end %>
            <% if inbox_credit_cards.any? %>
              <optgroup label="<%= t("transactions.ledger.filter_cards") %>">
                <% inbox_credit_cards.each do |card| %>
                  <option value="credit_card-<%= card.id %>" <%= "selected" if instrument_token == "credit_card-#{card.id}" %>><%= card.display_name %></option>
                <% end %>
              </optgroup>
            <% end %>
          </select>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <%# List view %>
  <div data-ledger-target="listView">
    <% rows = all_rows
       rows = rows.select { |r| r.direction == "expense" }  if current_filter == "expenses"
       rows = rows.select { |r| r.direction == "income" }   if current_filter == "incomes"
       rows = rows.select { |r| r.direction == "transfer" } if current_filter == "transfers" %>
    <%= render "transactions/ledger_list", rows: rows, month: month, filter: current_filter %>
  </div>

  <%# By-category view (R6) — toggled in, never a nested disclosure %>
  <% if has_expenses %>
    <div data-ledger-target="categoryView" hidden class="pt-1">
      <%= render "transactions/category_bars", rows: all_rows, month: month %>
    </div>
  <% end %>
</div>
