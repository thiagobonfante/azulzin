<%# locals: rows, month, filter — the grouped, day-sectioned list. Rendered inside the ledger
    frame and re-rendered wholesale on create so a first entry replaces the empty state cleanly. %>
<div id="ledger_list" class="flex flex-col">
  <% if rows.any? %>
    <% limit = params[:show_all].present? ? rows.size : 200 %>
    <% rows.first(limit).group_by(&:occurred_on).each do |day, day_rows| %>
      <div data-ledger-target="group">
        <div class="sticky top-0 z-10 bg-base-200 px-2 py-1 text-xs font-medium text-base-content/60"><%= l(day, format: :weekday_day) %></div>
        <div class="divide-y divide-base-300/50 [&>turbo-frame:nth-of-type(even)]:bg-base-200/40">
          <% day_rows.each do |txn| %>
            <%= render "transactions/ledger_row", transaction: txn %>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Totals footer — expenses split by instrument (debit account vs card) + the month total.
        Summed over all filtered rows, not just the displayed slice, so it stays true when capped. %>
    <% expense_rows = rows.select { |r| r.direction == "expense" } %>
    <% if expense_rows.any? %>
      <% debit_total  = expense_rows.reject(&:credit_card_id).sum(&:amount_cents) %>
      <% credit_total = expense_rows.select(&:credit_card_id).sum(&:amount_cents) %>
      <div data-ledger-target="totals" class="mt-2 space-y-1 border-t border-base-300/70 px-2 pt-2 text-xs tabular-nums">
        <div class="flex justify-between text-base-content/60">
          <span><%= t("transactions.ledger.totals.debit") %></span>
          <span><%= brl(debit_total) %></span>
        </div>
        <div class="flex justify-between text-base-content/60">
          <span><%= t("transactions.ledger.totals.credit") %></span>
          <span><%= brl(credit_total) %></span>
        </div>
        <div class="flex justify-between font-medium text-base-content">
          <span><%= t("transactions.ledger.totals.total") %></span>
          <span><%= brl(debit_total + credit_total) %></span>
        </div>
      </div>
    <% end %>

    <p data-ledger-target="noResults" hidden class="px-2 py-6 text-center text-sm text-base-content/50">
      <%= t("transactions.ledger.no_results") %>
    </p>

    <% if rows.size > limit %>
      <div class="mt-3 text-center">
        <%= link_to t("transactions.ledger.show_more"),
              transactions_path(month: month.strftime("%Y-%m"), filter: (filter == "all" ? nil : filter), show_all: 1),
              class: "btn btn-ghost btn-sm text-primary" %>
      </div>
    <% end %>
  <% else %>
    <%= render "transactions/ledger_empty", month: month %>
  <% end %>
</div>
