<%# locals: transaction — display row; clicking it loads the edit form into this frame (R7).
    Money in reads green with a +; expenses wear their category color/icon (or a merchant
    monogram); transfers stay neutral. No in/out arrows — the color + sign carry direction. %>
<% search_text = [ transaction.merchant, transaction.description, transaction.commitment&.name, transaction.category&.name,
                   transaction.bank_account&.display_name, transaction.credit_card&.display_name,
                   transaction.transfer_to_bank_account&.display_name ].compact.join(" ").downcase %>
<%= turbo_frame_tag dom_id(transaction, :row), class: "block",
      data: { ledger_target: "row", search: search_text } do %>
  <%# The "Hoje" page threads its context (and active chip filter) through the edit link so
      update/destroy can refresh that page's figures — self-contained: params[:action] covers
      the page render, params[:context] a re-render inside a recent-context stream response. %>
  <% recent_ctx = ("recent" if params[:action] == "recent" || params[:context] == "recent") %>
  <%= link_to edit_transaction_path(transaction, month: params[:month], context: recent_ctx,
        category: (params[:category].presence if recent_ctx)),
        data: { turbo_frame: "entry_form", action: "click->entry-modal#open" },
        class: "flex items-center gap-3 rounded-lg px-2 py-2.5 transition-colors hover:bg-base-300/40" do %>
    <%= render "transactions/row_display", transaction: transaction %>
  <% end %>
<% end %>
