<%# locals: transaction, kind — inline add form; kind tabs are server-rendered links (no JS).
    Expense/income share one form whose entry-instrument controller powers the avatar picker
    (and, for expenses, the payment-method segmented control that auto-selects a card/account). %>
<% multi_account = Current.account.bank_accounts.kept.count >= 2 %>
<%= turbo_frame_tag "entry_form" do %>
    <h3 class="mb-3 font-display text-lg font-bold"><%= t("transactions.new_entry.title_new") %></h3>
    <div class="mb-3 flex gap-1">
      <%# The Transferência tab is hidden with a single account — there's nowhere to transfer (R5). %>
      <% (multi_account ? %w[expense income transfer] : %w[expense income]).each do |k| %>
        <%= link_to t("transactions.new_entry.#{k}"),
              new_transaction_path(kind: k, month: params[:month], context: params[:context].presence),
              class: "btn btn-xs #{kind == k ? "btn-primary" : "btn-ghost"}" %>
      <% end %>
    </div>

    <% if kind == "transfer" %>
      <%= form_with url: transfers_path(month: params[:month], context: params[:context].presence),
            method: :post, class: "grid gap-2 sm:grid-cols-2" do %>
        <% if transaction.errors.any? %>
          <div class="alert alert-error col-span-full py-1 text-xs" role="alert"><span><%= transaction.errors.full_messages.to_sentence %></span></div>
        <% end %>
        <div class="form-control">
          <label class="mb-1 text-xs text-base-content/60"><%= t("transfers.form.from") %></label>
          <%= collection_select :transfer, :bank_account_id, Current.account.bank_accounts.kept.includes(:institution).order(:created_at), :id, :display_name,
                { include_blank: false }, class: "select select-bordered select-sm w-full" %>
        </div>
        <div class="form-control">
          <label class="mb-1 text-xs text-base-content/60"><%= t("transfers.form.to") %></label>
          <%= collection_select :transfer, :transfer_to_bank_account_id, Current.account.bank_accounts.kept.includes(:institution).order(:created_at), :id, :display_name,
                { include_blank: false, selected: params[:to] }, class: "select select-bordered select-sm w-full" %>
        </div>
        <div class="form-control">
          <label class="mb-1 text-xs text-base-content/60"><%= t("transfers.form.amount") %></label>
          <label class="input input-bordered input-sm flex items-center gap-1">
            <span class="text-base-content/50"><%= t("money.symbol") %></span>
            <%= text_field_tag "transfer[amount_reais]", params[:amount], inputmode: "decimal", required: true, placeholder: "0,00", class: "grow",
                  data: { controller: "money-mask", money_mask_cents_value: true, action: "input->money-mask#format" } %>
          </label>
        </div>
        <div class="form-control">
          <label class="mb-1 text-xs text-base-content/60"><%= t("transfers.form.date") %></label>
          <%= date_field_tag "transfer[occurred_on]", transaction.occurred_on, class: "input input-bordered input-sm w-full" %>
        </div>
        <div class="col-span-full flex justify-end gap-2 pt-1">
          <button type="button" data-action="entry-modal#close" class="btn btn-ghost btn-sm"><%= t("transactions.row.cancel") %></button>
          <%= submit_tag t("transfers.form.submit"), class: "btn btn-primary btn-sm" %>
        </div>
      <% end %>
    <% else %>
      <% expense = kind == "expense" %>
      <% has_cards = inbox_credit_cards.any? %>
      <% selected_method = transaction.payment_method.presence || (has_cards ? "credito" : "pix") %>
      <% selected_token = current_instrument_token(transaction) %>
      <%# Income lands in a bank account — pre-select the first so the destination is always visible. %>
      <% selected_token ||= "bank_account-#{inbox_bank_accounts.first.id}" if !expense && inbox_bank_accounts.any? %>
      <%= form_with model: transaction,
            url: transactions_path(kind: kind, month: params[:month], context: params[:context].presence), method: :post,
            data: { controller: "entry-instrument category-suggest", category_suggest_url_value: suggest_categories_path },
            class: "grid gap-2 sm:grid-cols-2" do |f| %>
        <% if transaction.errors.any? %>
          <div class="alert alert-error col-span-full py-1 text-xs" role="alert"><span><%= transaction.errors.full_messages.to_sentence %></span></div>
        <% end %>

        <%# Valor %>
        <div class="form-control">
          <%= f.label :amount_reais, t("transactions.row.amount"), class: "mb-1 text-xs text-base-content/60" %>
          <label class="input input-bordered input-sm flex items-center gap-1">
            <span class="text-base-content/50"><%= t("money.symbol") %></span>
            <%= f.text_field :amount_reais, inputmode: "decimal", required: true, placeholder: "0,00", class: "grow",
                  data: { controller: "money-mask", money_mask_cents_value: true, action: "input->money-mask#format" } %>
          </label>
        </div>

        <% if expense %>
          <%# Forma de pagamento (R: fills the space beside Valor; drives the instrument picker) %>
          <div class="form-control">
            <label class="mb-1 block text-xs text-base-content/60"><%= t("transactions.new_entry.payment_method") %></label>
            <%= f.hidden_field :payment_method, value: selected_method, data: { entry_instrument_target: "methodInput" } %>
            <div class="join">
              <% [ [ "credito", "credit_card", !has_cards ], [ "debito", "bank_account", false ],
                   [ "pix", "bank_account", false ], [ "boleto", "bank_account", false ] ].each do |key, type, disabled| %>
                <% on = key == selected_method %>
                <button type="button" data-entry-instrument-target="method" data-method="<%= key %>" data-type="<%= type %>"
                        data-active="<%= on %>" data-action="entry-instrument#selectMethod" <%= "disabled" if disabled %>
                        class="btn btn-xs join-item <%= on ? "btn-primary" : "btn-ghost" %>">
                  <%= t("transactions.new_entry.methods.#{key}") %>
                </button>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# Estabelecimento %>
        <div class="form-control">
          <%= f.label :merchant, t("transactions.row.merchant"), class: "mb-1 text-xs text-base-content/60" %>
          <%= f.text_field :merchant, placeholder: t("transactions.row.merchant_placeholder"),
                data: { action: "change->category-suggest#fetch" }, class: "input input-bordered input-sm w-full" %>
        </div>

        <%# Data %>
        <div class="form-control">
          <%= f.label :occurred_on, t("transactions.row.date"), class: "mb-1 text-xs text-base-content/60" %>
          <%= f.date_field :occurred_on, value: transaction.occurred_on, class: "input input-bordered input-sm w-full" %>
        </div>

        <%# Conta ou cartão — brand-avatar picker (income: the account the money lands in) %>
        <div class="form-control">
          <label class="mb-1 text-xs text-base-content/60"><%= expense ? t("transactions.row.instrument") : t("incomes.bank_account") %></label>
          <%= render "transactions/instrument_picker",
                accounts: inbox_bank_accounts, cards: (expense ? inbox_credit_cards : []),
                selected_token: selected_token, placeholder: t("transactions.row.unassigned") %>
        </div>

        <% if expense %>
          <%# Sits beside Conta ou cartão (no col-span) so the form stays three tight rows. %>
          <div class="form-control">
            <label class="mb-1 flex items-center gap-1 text-xs text-base-content/60">
              <%= t("transactions.row.category") %>
              <span data-category-suggest-target="hint" hidden class="badge badge-ghost badge-xs"><%= t("transactions.new_entry.suggestion_hint") %></span>
            </label>
            <%= render "categories/picker", field_name: "transaction[category_id]", selected_id: transaction.category_id %>
          </div>
        <% end %>

        <%# Comprovante (up-tier F5) — optional photo/PDF attached to the entry. %>
        <div class="form-control col-span-full">
          <%= f.label :receipt, t("transactions.row.attach_receipt"), class: "mb-1 text-xs text-base-content/60" %>
          <%= f.file_field :receipt, accept: Transaction::RECEIPT_CONTENT_TYPES.join(","),
                class: "file-input file-input-bordered file-input-sm w-full" %>
        </div>

        <div class="col-span-full flex justify-end gap-2 pt-1">
          <button type="button" data-action="entry-modal#close" class="btn btn-ghost btn-sm"><%= t("transactions.row.cancel") %></button>
          <%= f.submit t("transactions.new.submit"), class: "btn btn-primary btn-sm" %>
        </div>
      <% end %>
    <% end %>
<% end %>
