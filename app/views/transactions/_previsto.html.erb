<%# locals: occurrences, income_occurrences, ledger, month — future months (§4.8). Deterministic
    expectations, nothing invented; not editable — each row links to its source of truth. %>
<% posted = ledger.to_a %>
<section class="rounded-box border border-base-300/70 bg-base-100 p-4 shadow-sm">
  <header class="mb-1"><h2 class="text-sm font-semibold"><%= t("transactions.ledger.title") %></h2></header>
  <p class="mb-3 text-xs text-base-content/50"><%= t("transactions.projection.notice") %></p>

  <% if income_occurrences.blank? && occurrences.empty? && posted.empty? %>
    <div class="rounded-box border border-dashed border-base-300 px-4 py-8 text-center">
      <p class="text-sm text-base-content/60"><%= t("transactions.ledger.empty_future", month: l(month, format: :month_year)) %></p>
    </div>
  <% else %>
    <div class="divide-y divide-base-300/40">
      <% income_occurrences.to_a.each do |income| %>
        <div class="flex items-center gap-2 py-2 opacity-70">
          <span class="w-4 text-center text-success">↑</span>
          <div class="min-w-0 flex-1">
            <p class="truncate text-sm"><%= link_to income.name, incomes_path, class: "hover:underline" %></p>
            <p class="text-xs text-base-content/50"><%= l(income.expected_on(month), format: :short) %></p>
          </div>
          <span class="badge badge-ghost badge-xs"><%= t("transactions.projection.expected") %></span>
          <span class="tabular-nums text-sm text-success">+<%= brl(income.amount_cents) %></span>
        </div>
      <% end %>

      <% occurrences.each do |occurrence| %>
        <%= render "commitments/occurrence", occurrence: occurrence, context: :previsto %>
      <% end %>

      <% posted.each do |txn| %>
        <div id="<%= dom_id(txn, :row) %>" class="flex items-center gap-2 py-2 opacity-70">
          <span class="w-4 text-center text-base-content/70">↓</span>
          <div class="min-w-0 flex-1">
            <p class="truncate text-sm">
              <% label = txn.merchant.presence || txn.description.presence || t("transactions.hero.expenses") %>
              <%= txn.commitment ? link_to(label, commitment_path(txn.commitment), class: "hover:underline") : label %>
              <% if txn.installment_number %><span class="text-xs text-base-content/50"><%= txn.installment_number %>/<%= txn.commitment&.installments_count %></span><% end %>
            </p>
          </div>
          <span class="badge badge-ghost badge-xs"><%= t("transactions.projection.expected") %></span>
          <span class="tabular-nums text-sm"><%= brl(txn.amount_cents) %></span>
        </div>
      <% end %>
    </div>
  <% end %>
</section>
