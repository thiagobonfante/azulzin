<%# locals: window, category_filter — category chips for the "Hoje" view. Derived from the
    UNFILTERED window rows (always short, and escape stays visible when a filter empties the
    days). Plain GET links — the URL is the state, same as every hub filter. %>
<% cats = window.map(&:category).compact.uniq.sort_by(&:name) %>
<% has_uncategorized = window.any? { |r| r.category_id.nil? && r.direction == "expense" } %>
<% if cats.any? || has_uncategorized %>
  <div class="flex gap-2 overflow-x-auto pb-1">
    <%= link_to t("transactions.recent.all_categories"), recent_transactions_path,
          class: "btn btn-xs shrink-0 #{category_filter ? "btn-ghost" : "btn-primary"}" %>
    <% cats.each do |cat| %>
      <%= link_to recent_transactions_path(category: cat.id),
            class: "btn btn-xs shrink-0 gap-1.5 #{category_filter == cat ? "btn-primary" : "btn-ghost"}" do %>
        <span class="h-2 w-2 shrink-0 rounded-full" style="background-color: <%= cat.display_color %>"></span>
        <%= cat.name %>
      <% end %>
    <% end %>
    <% if has_uncategorized %>
      <%= link_to t("transactions.ledger.uncategorized"), recent_transactions_path(category: "none"),
            class: "btn btn-xs shrink-0 #{category_filter == :none ? "btn-primary" : "btn-ghost"}" %>
    <% end %>
  </div>
<% end %>
