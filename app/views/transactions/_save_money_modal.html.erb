<%# locals: summary, month — the "guardar dinheiro" modal, opened from the hero's sobra number
    (surplus-cta controller). It lives inside #hero, so the hub_figures replace on success tears
    the open dialog down with it — no explicit close needed. %>
<%# modal-bottom sm:modal-middle: a thumb-reachable bottom sheet on mobile, centered on desktop. %>
<dialog data-surplus-cta-target="dialog" class="modal modal-bottom sm:modal-middle">
  <%# Full-width bottom sheet on mobile (a max-w there corner-pins the box: modal-bottom is
      place-items:end); cap the width only from sm: up. %>
  <div class="modal-box sm:max-w-md">
    <form method="dialog">
      <button class="btn btn-ghost btn-sm btn-circle absolute right-2 top-2"
              aria-label="<%= t("transactions.hero.save_modal.close") %>">✕</button>
    </form>
    <h3 class="font-display text-lg font-bold"><%= t("transactions.hero.save_cta") %></h3>
    <p class="mt-1 text-sm text-base-content/60">
      <%= t("transactions.hero.save_modal.subtitle", amount: brl(summary.remaining_cents)) %>
    </p>
    <%= render "transactions/save_money_form", summary: summary, month: month, error_message: nil %>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button aria-label="<%= t("transactions.hero.save_modal.close") %>"></button>
  </form>
</dialog>
