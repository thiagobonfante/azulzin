<% if @saved %>
  <%= turbo_stream.update "new_entry", "" %>
  <%# Re-render the whole ledger frame (not a prepend) so a first entry replaces the empty state,
      brings in the toolbar, and lands under its day header. Rows billed to another month aren't here. %>
  <%= turbo_stream.replace "movements_ledger" do %>
    <%= turbo_frame_tag "movements_ledger" do %>
      <%= render "transactions/ledger_body", ledger: @ledger, month: viewed_month %>
    <% end %>
  <% end %>
  <%= render "transactions/hub_figures" %>
  <%# A card purchase after the fatura closed lands on a later month's bill — it isn't in this
      month's list, so say where it went instead of letting it seem to vanish (item 4). %>
  <% if @transaction.billing_month != viewed_month %>
    <%= turbo_stream.prepend "toasts" do %>
      <%= link_to transactions_path(month: @transaction.billing_month.strftime("%Y-%m")),
            data: { controller: "toast" }, class: "alert alert-info cursor-pointer shadow-lg" do %>
        <span><%= t("transactions.create.future_bill", month: l(@transaction.billing_month, format: :month_year)) %></span>
      <% end %>
    <% end %>
  <% end %>
<% else %>
  <%= turbo_stream.replace "new_entry", partial: "transactions/new_entry",
        locals: { transaction: @transaction, kind: @transaction.direction } %>
<% end %>
