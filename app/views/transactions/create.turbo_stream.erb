<% if @saved %>
  <%= turbo_stream.update "entry_form", "" %>
  <%# Re-render the whole ledger frame (not a prepend) so a first entry replaces the empty state,
      brings in the toolbar, and lands under its day header. Rows billed to another month aren't here. %>
  <%= turbo_stream.replace "movements_ledger" do %>
    <%= turbo_frame_tag "movements_ledger" do %>
      <%= render "transactions/ledger_body", ledger: @ledger, month: viewed_month %>
    <% end %>
  <% end %>
  <%= render "transactions/hub_figures" %>
  <% if @recent_rows %>
    <%# Add from the Recentes page: the new row lands in the day list immediately. %>
    <%= turbo_stream.replace "recent_summary", partial: "transactions/recent_sections",
          locals: { rows: @recent_rows, window_empty: @recent_window.empty?, today: @recent_today } %>
    <%= turbo_stream.replace "recent_chips", partial: "transactions/recent_chips",
          locals: { window: @recent_window, category_filter: @recent_category } %>
  <% end %>
  <%# A card purchase after the fatura closed lands on a later month's bill — visible in this
      month's list since the purchase-date union, but say where it bills anyway (item 4). %>
  <% if @transaction.billing_month != viewed_month %>
    <%= turbo_stream.prepend "toasts" do %>
      <%= render "shared/toast", variant: :info,
            href: transactions_path(month: @transaction.billing_month.strftime("%Y-%m")),
            message: t("transactions.create.future_bill", month: l(@transaction.billing_month, format: :month_year)) %>
    <% end %>
  <% end %>
<% else %>
  <%= turbo_stream.replace "entry_form", partial: "transactions/new_entry",
        locals: { transaction: @transaction, kind: @transaction.direction } %>
<% end %>
