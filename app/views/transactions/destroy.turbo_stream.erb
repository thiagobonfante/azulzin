<%# Reversed/discarded → rejected: leaves both the tray and the ledger. Remove from each
    (no-op where absent); refresh the tray chrome and the hub figures (spend/sobra dropped). %>
<%= turbo_stream.remove dom_id(@transaction) %>
<%= turbo_stream.remove dom_id(@transaction, :row) %>

<%= turbo_stream.replace "sidebar_pending_count", pending_nav_badge %>
<% if Current.account.transactions.pending_inbox.exists? %>
  <%= turbo_stream.replace "pending_tray_count" do %>
    <span id="pending_tray_count" class="badge badge-warning badge-sm"><%= Current.account.transactions.pending_inbox.count %></span>
  <% end %>
<% else %>
  <%= turbo_stream.remove "pending_tray" %>
<% end %>

<%= render "transactions/hub_figures" %>

<% if @recent_rows %>
  <%# Recent-context delete: fresh day sections keep the figures and empty states honest. %>
  <%= turbo_stream.replace "recent_summary", partial: "transactions/recent_sections",
        locals: { rows: @recent_rows, window_empty: @recent_window.empty?, today: @recent_today } %>
  <%= turbo_stream.replace "recent_chips", partial: "transactions/recent_chips",
        locals: { window: @recent_window, category_filter: @recent_category } %>
<% end %>
