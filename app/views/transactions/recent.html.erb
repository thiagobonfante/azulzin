<% content_for :title, t(".meta_title") %>

<%# "Hoje" (.plans/today-expenses): purchase-date view of today + yesterday. Rows reuse the
    ledger row partial verbatim and open the same edit drawer; pending rows surface in the
    shared tray, never inside the day lists. The submit-end listener is @document for the
    same reason as the hub: delete links submit ephemeral forms appended to the body. %>
<%# The ledger controller powers the same client-side search as the hub — rows already bake
    their text + value into data-search via _ledger_row. %>
<div class="flex flex-col gap-6" data-controller="entry-modal ledger"
     data-action="turbo:submit-end@document->entry-modal#submitEnd">
  <header class="flex items-start justify-between gap-2">
    <div>
      <h1 class="font-display text-2xl font-extrabold tracking-tight sm:text-3xl"><%= t(".title") %></h1>
      <p class="mt-1 text-base-content/60"><%= t(".subtitle") %></p>
    </div>
    <%= link_to new_transaction_path(kind: :expense, context: "recent"),
          data: { turbo_frame: "entry_form", action: "click->entry-modal#open" },
          class: "btn btn-ghost btn-sm shrink-0 text-primary" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
      <%= t("transactions.ledger.add") %>
    <% end %>
  </header>

  <%# Accepted v1 edge (.plans/today-expenses §7): confirming a tray row here posts it into
      "today", but the day lists/figures below refresh only on the next visit — the tray is
      shared with the dashboard and its streams target hub figures. Revisit if the daily
      ritual proves it annoying. %>
  <%= render "transactions/pending_tray", pending: @pending %>

  <%# One toolbar row — search + the Filtros trigger (hub idiom): the category chips live in
      the sheet, saving the standalone chip row. A clear (×) shows while a chip is active. %>
  <div class="flex items-center gap-2" data-controller="modal">
    <label class="input input-bordered input-sm flex min-w-0 flex-1 items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 10.5a6.5 6.5 0 11-13 0 6.5 6.5 0 0113 0z" /></svg>
      <input type="search" data-ledger-target="search" data-action="input->ledger#filter"
             placeholder="<%= t("transactions.ledger.search_placeholder") %>"
             class="grow border-0 bg-transparent p-0 focus:outline-none" autocomplete="off">
    </label>

    <div class="ml-auto flex shrink-0 items-center gap-1">
      <% if @category %>
        <%= link_to recent_transactions_path,
              class: "btn btn-sm btn-ghost btn-square text-base-content/50 hover:text-error",
              aria: { label: t("transactions.ledger.filter_clear") } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
        <% end %>
      <% end %>
      <button type="button" data-action="modal#open"
              class="btn btn-sm btn-ghost gap-1 <%= "text-primary" if @category %>">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z" /></svg>
        <%= t("transactions.ledger.filters_button") %>
        <% if @category %><span class="h-2 w-2 rounded-full bg-primary" aria-hidden="true"></span><% end %>
      </button>
    </div>

    <dialog data-modal-target="dialog" class="modal modal-bottom sm:modal-middle">
      <div class="modal-box sm:max-w-sm text-left">
        <form method="dialog">
          <button class="btn btn-ghost btn-sm btn-circle absolute right-2 top-2" aria-label="<%= t("transactions.new_entry.close") %>">✕</button>
        </form>
        <h3 class="mb-4 font-display text-lg font-bold"><%= t("transactions.ledger.filter_sheet_title") %></h3>
        <p class="mb-1.5 text-xs font-medium text-base-content/60"><%= t("transactions.row.category") %></p>
        <%= render "transactions/recent_chips", window: @window, category_filter: @category %>
      </div>
      <form method="dialog" class="modal-backdrop">
        <button aria-label="<%= t("transactions.new_entry.close") %>">close</button>
      </form>
    </dialog>
  </div>

  <%= render "transactions/recent_sections", rows: @rows, window_empty: @window.empty?, today: @today %>

  <p data-ledger-target="noResults" hidden class="py-4 text-center text-sm text-base-content/50">
    <%= t("transactions.ledger.no_results") %>
  </p>

  <div class="text-center">
    <%= link_to transactions_path, class: "btn btn-ghost btn-sm text-primary" do %>
      <%= t(".see_month") %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
    <% end %>
  </div>

  <%# Mobile quick-add FAB — same affordance as the hub's; no bottom tab bar here, so it sits
      at the viewport edge. Hidden on lg+ where the header button is in reach. %>
  <%= link_to new_transaction_path(kind: :expense, context: "recent"),
        data: { turbo_frame: "entry_form", action: "click->entry-modal#open" },
        class: "btn btn-primary btn-circle btn-lg fixed bottom-6 left-1/2 z-20 -translate-x-1/2 shadow-lg lg:hidden",
        aria: { label: t("transactions.fab_add") } do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
  <% end %>

  <%= render "transactions/entry_modal" %>
</div>
