<% if @saved %>
  <%= turbo_stream.update "entry_form", "" %>
  <% @transactions.each do |transaction| %>
    <% if transaction.billing_month == viewed_month %>
      <%= turbo_stream.prepend "ledger_list", partial: "transactions/ledger_row", locals: { transaction: transaction } %>
    <% end %>
  <% end %>
  <%= render "transactions/hub_figures" %>
  <% if @to_savings %>
    <%= turbo_stream.prepend "toasts" do %>
      <%= render "shared/toast", variant: :success,
            message: t("transfers.saved_celebration", amount: brl(@transactions.sum(&:amount_cents)), total: brl(summary.guardado_cents)) %>
    <% end %>
    <%# Goal boost (round 3 P3): the money landed in a goal's caixinha — confirm the
        acceleration (purchase: fresh derived forecast) with a click-through to the goal. %>
    <% if @boosted_goal %>
      <% projected = (Goals::Progress.new(@boosted_goal).projected_done_on if @boosted_goal.purchase?) %>
      <%= turbo_stream.prepend "toasts" do %>
        <%= render "shared/toast", variant: :info, href: goal_path(@boosted_goal),
              message: (projected ?
                t("transfers.saved_goal_boost", goal: @boosted_goal.name, month: l(projected, format: :month_year)) :
                t("transfers.saved_goal_boost_savings", goal: @boosted_goal.name)) %>
      <% end %>
    <% end %>
  <% end %>
<% elsif params[:sources].present? %>
  <%# Modal batch failed — re-render the form in place (same id), keeping the dialog open. %>
  <%= turbo_stream.replace "save_money_form", partial: "transactions/save_money_form",
        locals: { summary: summary, month: viewed_month, error_message: @error_message } %>
<% else %>
  <%= turbo_stream.replace "entry_form", partial: "transactions/new_entry", locals: { transaction: @transaction, kind: "transfer" } %>
<% end %>
