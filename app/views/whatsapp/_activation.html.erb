<%# Persistent "activate WhatsApp" prompt. Rendered on the dashboard (persistent reminder)
    and on the onboarding profile step once the phone is set. The caller generates `code`
    via WhatsappActivation#prepare_whatsapp_activation and passes it in; a blank code (already
    verified, or no phone yet) renders nothing. %>
<% code = local_assigns[:code] %>
<% if code.present? %>
  <% number = whatsapp_display_number %>
  <div class="mb-8 rounded-box border border-primary/30 bg-primary/5 p-5 shadow-sm sm:p-6">
    <div class="flex items-start gap-4">
      <span class="inline-grid h-11 w-11 shrink-0 place-items-center rounded-full bg-primary/15 text-primary">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.76c0 1.6 1.123 2.994 2.707 3.227 1.068.157 2.148.279 3.238.364.466.037.893.281 1.153.671L12 21l2.652-3.978c.26-.39.687-.634 1.153-.67 1.09-.086 2.17-.208 3.238-.365 1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" /></svg>
      </span>

      <div class="min-w-0 flex-1">
        <h2 class="font-display text-lg font-bold"><%= t(".title") %></h2>
        <p class="mt-1 text-sm text-base-content/70"><%= t(".subtitle") %></p>

        <div class="mt-4 rounded-box border border-base-300/70 bg-base-100 px-4 py-3">
          <p class="text-xs font-medium uppercase tracking-wide text-base-content/45"><%= t(".code_label") %></p>
          <p class="mt-0.5 select-all font-mono text-2xl font-extrabold tracking-widest text-primary"><%= code %></p>
        </div>

        <p class="mt-4 text-sm text-base-content/80">
          <% if number.present? %>
            <%= t(".instructions_html", code: tag.strong(code), number: tag.strong(number)) %>
          <% else %>
            <%= t(".instructions_pending_html", code: tag.strong(code)) %>
          <% end %>
        </p>

        <div class="mt-4">
          <%= link_to t(".refresh"), request.path, class: "btn btn-primary btn-sm" %>
        </div>
      </div>
    </div>
  </div>
<% end %>
