<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/inicio_nav_host"
            android:name="dev.hotwire.navigation.navigator.NavigatorHost"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/chat_nav_host"
            android:name="dev.hotwire.navigation.navigator.NavigatorHost"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/movimentos_nav_host"
            android:name="dev.hotwire.navigation.navigator.NavigatorHost"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/recentes_nav_host"
            android:name="dev.hotwire.navigation.navigator.NavigatorHost"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/mais_nav_host"
            android:name="dev.hotwire.navigation.navigator.NavigatorHost"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Menu items are built by HotwireBottomNavigationController from the tabs list
         in MainActivity — no res/menu file. -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="@color/bottom_nav_item"
        app:itemTextColor="@color/bottom_nav_item"
        app:itemActiveIndicatorStyle="@style/BottomNavIndicator" />
</LinearLayout>
