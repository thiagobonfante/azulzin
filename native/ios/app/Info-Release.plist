	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>GoogleSSO</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.648002270527-p5ia5bhvviooa0ne51rl7vocbma0oplu</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
