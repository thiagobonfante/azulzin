# azulzin WhatsApp sidecar — environment

# HTTP port the sidecar listens on
PORT=3001
NODE_ENV=production

# Single Rails webhook endpoint (no tenant path). The sidecar POSTs every event here.
RAILS_WEBHOOK_URL=https://app.azulzin.com.br/api/whatsapp/webhook

# Shared bearer secret, used in BOTH directions:
#   - sidecar -> Rails: Authorization: Bearer <token> on every webhook POST
#   - Rails -> sidecar: Authorization: Bearer <token> on every non-/health request
RAILS_API_TOKEN=change-me

# Where LocalAuth stores the Chrome user-data dir. MUST be a persistent volume in prod
# (otherwise every deploy forces a fresh QR scan). Session lives in
# <SESSION_DATA_PATH>/session-azulzin-main/
SESSION_DATA_PATH=/app/.wwebjs_auth

# System Chromium (set by the Dockerfile). Leave empty to use puppeteer's bundled Chrome.
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Global outbound throttle: minimum interval between two sends (anti-ban). >= 1500 recommended.
SEND_MIN_INTERVAL_MS=1500

# When true, the sidecar does NOT auto-initialize the client on boot; it waits for
# POST /session/initialize. Useful in dev / CI.
SKIP_AUTO_RECONNECT=false
